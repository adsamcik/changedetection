@page "/test-setup"
@rendermode InteractiveWebAssembly
@using ChangeDetection.Shared.Dtos
@using ChangeDetection.Client.Components
@inject NavigationManager Navigation

<PageTitle>Test Setup Chat</PageTitle>

<h1>Test Setup Chat</h1>
<p>Testing the SetupChat component directly.</p>

<SetupChat OnSetupCompleted="HandleSetupCompleted"
           OnError="HandleError"
           InitialInput="https://example.com I want to watch for changes" />

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="color: red; margin-top: 1rem;">@errorMessage</div>
}

@code {
    private string? errorMessage;

    private Task HandleSetupCompleted(SetupCompletedDto result)
    {
        Navigation.NavigateTo($"/watches/{result.WatchId}");
        return Task.CompletedTask;
    }

    private Task HandleError(string error)
    {
        errorMessage = error;
        return Task.CompletedTask;
    }
}
