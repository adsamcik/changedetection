@page "/groupwatch"
@page "/groupwatch/setup"
@rendermode InteractiveAuto
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Group Watch Setup - Change Detection</PageTitle>

<div class="groupwatch-container">
    <header class="page-header">
        <div class="header-content">
            <h1>🌐 Group Watch Setup</h1>
            <p class="subtitle">Describe what you want to monitor and we'll discover relevant portals automatically</p>
        </div>
        <button class="back-button" @onclick="GoBack" aria-label="Go back to dashboard">
            <span class="icon" aria-hidden="true">←</span> Dashboard
        </button>
    </header>

    @* Reconnecting banner *@
    @if (_isReconnecting)
    {
        <div class="reconnect-banner" role="status" aria-live="polite">
            <span class="spinner-sm" aria-hidden="true"></span>
            <span>Connection lost. Reconnecting...</span>
        </div>
    }

    @* Error alert *@
    @if (_hasError)
    {
        <div class="alert alert-error" role="alert">
            <strong>⚠️ Error:</strong> @_errorMessage
            <button class="alert-dismiss" @onclick="DismissError" aria-label="Dismiss error">×</button>
        </div>
    }

    @* ── Phase 1: Input ── *@
    @if (_phase == Phase.Input)
    {
        <div class="input-phase">
            <div class="input-card">
                <div class="input-icon" aria-hidden="true">🎯</div>
                <h2>What jobs do you want to watch?</h2>
                <p class="input-hint">Describe the type of jobs and locations you're interested in. We'll find the best career portals to monitor.</p>

                <div class="input-wrapper">
                    <textarea @ref="_inputElement"
                              @bind="_userInput"
                              @bind:event="oninput"
                              @onkeydown="HandleKeyDown"
                              placeholder="e.g., Research assistant jobs in Copenhagen biology"
                              class="query-input"
                              rows="3"
                              disabled="@(!_hasRendered)" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_userInput))
                {
                    <div class="input-hint-action">
                        <span>✨ Press Enter or click the button below</span>
                    </div>
                }

                <button class="btn btn-primary btn-block"
                        disabled="@(string.IsNullOrWhiteSpace(_userInput) || _isDiscovering)"
                        @onclick="StartDiscovery">
                    🔍 Discover Portals
                </button>

                <div class="how-it-works">
                    <h3>How it works</h3>
                    <div class="step">
                        <span class="step-num">1</span>
                        <span>Describe your job search intent</span>
                    </div>
                    <div class="step">
                        <span class="step-num">2</span>
                        <span>AI discovers relevant career portals</span>
                    </div>
                    <div class="step">
                        <span class="step-num">3</span>
                        <span>Review and confirm which portals to monitor</span>
                    </div>
                    <div class="step">
                        <span class="step-num">4</span>
                        <span>Watches are created for each portal automatically</span>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Phase 2: Discovery (streaming progress) ── *@
    @if (_phase == Phase.Discovery)
    {
        <div class="discovery-phase">
            <div class="progress-card">
                <div class="progress-header">
                    <h2>Discovering portals</h2>
                    <p class="progress-query">"@_userInput"</p>
                </div>

                <div class="progress-steps">
                    @foreach (var step in _progressSteps)
                    {
                        <div class="progress-step @step.Status.ToString().ToLowerInvariant()">
                            <span class="step-icon" aria-hidden="true">
                                @switch (step.Status)
                                {
                                    case StepStatus.Completed:
                                        <text>✅</text>
                                        break;
                                    case StepStatus.Active:
                                        <span class="spinner-sm"></span>
                                        break;
                                    case StepStatus.Failed:
                                        <text>❌</text>
                                        break;
                                    default:
                                        <text>○</text>
                                        break;
                                }
                            </span>
                            <div class="step-content">
                                <span class="step-label">@step.Label</span>
                                @if (!string.IsNullOrEmpty(step.Detail))
                                {
                                    <span class="step-detail">@step.Detail</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Phase 3: Confirmation (portal cards) ── *@
    @if (_phase == Phase.Confirmation)
    {
        <div class="confirmation-phase">
            <div class="confirmation-header">
                <h2>Discovered Portals</h2>
                <p class="confirmation-subtitle">
                    Found @_discoveredPortals.Count portal(s). Select which ones to monitor.
                </p>
            </div>

            <div class="portal-grid">
                @for (var i = 0; i < _discoveredPortals.Count; i++)
                {
                    var portal = _discoveredPortals[i];
                    var index = i;
                    <div class="portal-card @(portal.Selected ? "selected" : "") @(portal.Recommended ? "recommended" : "")">
                        <div class="portal-card-header">
                            <label class="portal-checkbox">
                                <input type="checkbox"
                                       checked="@portal.Selected"
                                       @onchange="() => TogglePortal(index)" />
                                <span class="checkmark"></span>
                            </label>
                            <div class="portal-card-title">
                                <span class="portal-name">@portal.Name</span>
                                @if (portal.Recommended)
                                {
                                    <span class="badge badge-recommended" title="Recommended by AI">⭐ Recommended</span>
                                }
                            </div>
                        </div>

                        <a href="@portal.Url" target="_blank" rel="noopener noreferrer" class="portal-url">
                            @TruncateUrl(portal.Url)
                        </a>

                        @if (!string.IsNullOrEmpty(portal.Platform))
                        {
                            <span class="badge badge-platform">@portal.Platform</span>
                        }

                        @if (!string.IsNullOrEmpty(portal.Reasoning))
                        {
                            <p class="portal-reasoning">@portal.Reasoning</p>
                        }
                    </div>
                }
            </div>

            <div class="confirmation-actions">
                <button class="btn btn-primary"
                        disabled="@(!_discoveredPortals.Any(p => p.Selected))"
                        @onclick="CreateWatches">
                    🚀 Create Watches (@_discoveredPortals.Count(p => p.Selected) selected)
                </button>
                <button class="btn btn-outline" @onclick="GoBackToInput">
                    ← Change query
                </button>
            </div>
        </div>
    }

    @* ── Phase 4: Creation (progress bar) ── *@
    @if (_phase == Phase.Creating)
    {
        <div class="creation-phase">
            <div class="creation-card">
                <h2>Creating watches</h2>
                <p class="creation-subtitle">Setting up monitoring for your selected portals...</p>

                <div class="creation-progress-bar">
                    <div class="creation-progress-fill"
                         style="width: @(CreationProgressPercent)%">
                    </div>
                </div>
                <p class="creation-counter">
                    Creating watch @(_creationCompleted + 1)/@_creationTotal...
                </p>

                <div class="creation-items">
                    @foreach (var item in _creationItems)
                    {
                        <div class="creation-item @item.Status.ToString().ToLowerInvariant()">
                            <span class="creation-item-icon" aria-hidden="true">
                                @switch (item.Status)
                                {
                                    case StepStatus.Completed:
                                        <text>✅</text>
                                        break;
                                    case StepStatus.Active:
                                        <span class="spinner-sm"></span>
                                        break;
                                    case StepStatus.Failed:
                                        <text>⚠️</text>
                                        break;
                                    default:
                                        <text>○</text>
                                        break;
                                }
                            </span>
                            <span class="creation-item-name">@item.Label</span>
                            @if (!string.IsNullOrEmpty(item.Detail))
                            {
                                <span class="creation-item-detail">@item.Detail</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Phase 5: Complete ── *@
    @if (_phase == Phase.Complete)
    {
        <div class="complete-phase">
            <div class="complete-card">
                <div class="complete-icon" aria-hidden="true">🎉</div>
                <h2>Group created!</h2>
                <p class="complete-message">
                    Monitoring @_creationCompleted portal(s). You'll be notified when matching jobs are found.
                </p>

                @if (_failedPortals > 0)
                {
                    <div class="complete-warning">
                        <span>⚠️</span> @_failedPortals portal(s) could not be set up and were skipped.
                    </div>
                }

                <div class="complete-actions">
                    @if (_groupId is not null)
                    {
                        <a href="@($"groupwatch/results/{_groupId}")" class="btn btn-primary">
                            📊 View Results
                        </a>
                    }
                    <button class="btn btn-outline" @onclick="CreateAnother">
                        ➕ Create Another
                    </button>
                    <a href="/" class="btn btn-outline">
                        🏠 Dashboard
                    </a>
                </div>
            </div>
        </div>
    }

    @* Connection status *@
    @if (_hasRendered && !_isConnected && !_hasError && _phase == Phase.Input)
    {
        <div class="connecting-indicator" role="status" aria-live="polite">
            <span class="spinner-sm" aria-hidden="true"></span>
            <span>Connecting... @_connectionDebug</span>
        </div>
    }
    @if (_hasError)
    {
        <div class="error-banner" role="alert">⚠️ @_errorMessage</div>
    }
</div>

@code {
    // ── Parameters ──
    [SupplyParameterFromQuery]
    public string? Input { get; set; }

    // ── State ──
    private HubConnection? _hubConnection;
    private CancellationTokenSource _cts = new();
    private Task? _streamingTask;
    private bool _disposed;

    private Phase _phase = Phase.Input;
    private string _userInput = "";
    private bool _isConnected;
    private bool _isReconnecting;
    private bool _isDiscovering;
    private bool _hasError;
    private string? _errorMessage;
    private string? _connectionDebug;
    private bool _hasRendered;
    private ElementReference _inputElement;

    // Discovery
    private List<ProgressStep> _progressSteps = [];

    // Confirmation
    private List<PortalSelection> _discoveredPortals = [];

    // Creation
    private int _creationCompleted;
    private int _creationTotal;
    private int _failedPortals;
    private List<ProgressStep> _creationItems = [];
    private string? _groupId;
    private List<string> _watchIds = [];

    private int CreationProgressPercent =>
        _creationTotal > 0 ? (int)((double)_creationCompleted / _creationTotal * 100) : 0;

    // ── Lifecycle ──

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;

            // If input was passed from SmartInput (unified entry point), pre-fill and auto-start
            if (!string.IsNullOrWhiteSpace(Input))
            {
                _userInput = Input.Trim();
                await InvokeAsync(StateHasChanged);
                // Small delay to let the UI render the input text before starting discovery
                await Task.Delay(300);
                await StartDiscovery();
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    // ── SignalR Connection ──

    private async Task ConnectToHub()
    {
        var hubUrl = Navigation.ToAbsoluteUri("/hubs/group-watch").ToString();
        _connectionDebug = hubUrl;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .AddJsonProtocol(options =>
            {
                options.PayloadSerializerOptions.Converters.Add(
                    new System.Text.Json.Serialization.JsonStringEnumConverter());
                options.PayloadSerializerOptions.PropertyNamingPolicy =
                    System.Text.Json.JsonNamingPolicy.CamelCase;
            })
            .Build();

        _hubConnection.Closed += async (_) =>
        {
            _isConnected = false;
            _isReconnecting = false;
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnecting += async (_) =>
        {
            _isConnected = false;
            _isReconnecting = true;
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnected += async (_) =>
        {
            _isConnected = true;
            _isReconnecting = false;
            await InvokeAsync(StateHasChanged);
        };

        try
        {
            using var connectionCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            await _hubConnection.StartAsync(connectionCts.Token);
            _isConnected = true;
            _connectionDebug = $"Connected to {hubUrl}";
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = $"{ex.GetType().Name}: {ex.Message}";
            _connectionDebug = $"Failed: {ex.GetType().Name} → {hubUrl}";
        }

    await InvokeAsync(StateHasChanged);
    }

    // ── Input handling ──

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            return StartDiscovery();
        }
        if (e.Key == "Escape")
        {
            _userInput = "";
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    // ── Phase transitions ──

    private async Task StartDiscovery()
    {
        if (string.IsNullOrWhiteSpace(_userInput))
            return;

        // Connect on demand if not yet connected
        if (_hubConnection is null || !_isConnected)
        {
            await ConnectToHub();
            if (!_isConnected)
            {
                _hasError = true;
                _errorMessage = "Could not connect to the server. Please try again.";
                await InvokeAsync(StateHasChanged);
                return;
            }
        }

        _isDiscovering = true;
        _phase = Phase.Discovery;
        _hasError = false;
        _errorMessage = null;
        _progressSteps =
        [
            new("🧠 Understanding your intent...", StepStatus.Active),
            new("🔍 Searching for career portals...", StepStatus.Pending),
            new("🤖 Analyzing results...", StepStatus.Pending)
        ];

        await InvokeAsync(StateHasChanged);
        _streamingTask = StreamDiscoveryAsync(_userInput.Trim());
    }

    private async Task StreamDiscoveryAsync(string query)
    {
        if (_hubConnection is null) return;

        try
        {
            await foreach (var progress in _hubConnection.StreamAsync<GroupWatchProgress>(
                "StartDiscovery", query, _cts.Token))
            {
                await OnProgressReceived(progress);
            }

            // Stream ended without error or explicit completion — handle gracefully
            if (_phase == Phase.Discovery && !_hasError)
            {
                _hasError = true;
                _errorMessage = "Discovery stream ended unexpectedly. Please try again.";
                _phase = Phase.Input;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* expected on dispose */ }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "stream");
            _phase = Phase.Input;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateWatches()
    {
        if (_hubConnection is null || !_isConnected) return;

        var selectedPortals = _discoveredPortals
            .Where(p => p.Selected)
            .Select(p => new ConfirmedPortalDto(p.Url, p.Name, p.Platform, p.Reasoning))
            .ToList();

        if (selectedPortals.Count == 0) return;

        _phase = Phase.Creating;
        _creationTotal = selectedPortals.Count;
        _creationCompleted = 0;
        _failedPortals = 0;
        _creationItems = selectedPortals
            .Select(p => new ProgressStep(p.Name ?? p.Url, StepStatus.Pending))
            .ToList();

        StateHasChanged();
        _streamingTask = StreamCreationAsync(_userInput.Trim(), selectedPortals);
    }

    private async Task StreamCreationAsync(string userInput, List<ConfirmedPortalDto> portals)
    {
        if (_hubConnection is null) return;

        try
        {
            await foreach (var progress in _hubConnection.StreamAsync<GroupWatchProgress>(
                "ConfirmPortals", userInput, portals, _cts.Token))
            {
                await OnProgressReceived(progress);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "stream");
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Progress handling ──

    private async Task OnProgressReceived(GroupWatchProgress progress)
    {
        if (_disposed) return;

        switch (progress.Phase)
        {
            case "Parsing":
                UpdateDiscoveryStep(0, StepStatus.Active, progress.Message);
                break;

            case "Searching":
                UpdateDiscoveryStep(0, StepStatus.Completed);
                UpdateDiscoveryStep(1, StepStatus.Active, progress.Message);
                break;

            case "Filtering":
                UpdateDiscoveryStep(1, StepStatus.Completed);
                UpdateDiscoveryStep(2, StepStatus.Active, progress.Message);
                break;

            case "PortalsReady":
                // All discovery steps complete — transition to confirmation
                UpdateDiscoveryStep(2, StepStatus.Completed);

                if (progress.Portals is { Count: > 0 })
                {
                    _discoveredPortals = progress.Portals.Select(p => new PortalSelection
                    {
                        Url = p.Url,
                        Name = p.Name,
                        Platform = p.Platform,
                        Reasoning = p.Reasoning,
                        Recommended = p.Recommended,
                        Selected = p.Recommended
                    }).ToList();

                    _phase = Phase.Confirmation;
                }
                else
                {
                    _hasError = true;
                    _errorMessage = "No portals were found matching your description. Try a different query.";
                    _phase = Phase.Input;
                }
                break;

            case "CreatingWatches":
                if (progress is { CompletedCount: not null, TotalCount: not null })
                {
                    _creationTotal = progress.TotalCount.Value;
                    _creationCompleted = progress.CompletedCount.Value;

                    // Update individual creation items
                    for (var i = 0; i < _creationItems.Count; i++)
                    {
                        if (i < _creationCompleted)
                            _creationItems[i] = _creationItems[i] with { Status = StepStatus.Completed };
                        else if (i == _creationCompleted)
                            _creationItems[i] = _creationItems[i] with
                            {
                                Status = StepStatus.Active,
                                Detail = progress.Message
                            };
                    }
                }
                break;

            case "Complete":
                _groupId = progress.GroupId;
                _watchIds = progress.WatchIds ?? [];
                _creationCompleted = _creationItems.Count(i => i.Status == StepStatus.Completed);

                // Mark any remaining as completed
                for (var i = 0; i < _creationItems.Count; i++)
                {
                    if (_creationItems[i].Status is StepStatus.Active or StepStatus.Pending)
                        _creationItems[i] = _creationItems[i] with { Status = StepStatus.Completed };
                }

                _creationCompleted = _creationItems.Count(i => i.Status == StepStatus.Completed);
                _failedPortals = _creationItems.Count(i => i.Status == StepStatus.Failed);
                _phase = Phase.Complete;
                break;

            case "Error":
                _hasError = true;
                _errorMessage = progress.Message;

                // If we're in creation, mark current item as failed but don't go back to input
                if (_phase == Phase.Creating)
                {
                    var activeIdx = _creationItems.FindIndex(i => i.Status == StepStatus.Active);
                    if (activeIdx >= 0)
                    {
                        _creationItems[activeIdx] = _creationItems[activeIdx] with
                        {
                            Status = StepStatus.Failed,
                            Detail = progress.Message
                        };
                        _failedPortals++;
                    }
                }
                else
                {
                    _phase = Phase.Input;
                }
                break;
        }

        if (!_disposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateDiscoveryStep(int index, StepStatus status, string? detail = null)
    {
        if (index < 0 || index >= _progressSteps.Count) return;
        _progressSteps[index] = _progressSteps[index] with
        {
            Status = status,
            Detail = detail ?? _progressSteps[index].Detail
        };
    }

    // ── UI helpers ──

    private void TogglePortal(int index)
    {
        if (index < 0 || index >= _discoveredPortals.Count) return;
        _discoveredPortals[index].Selected = !_discoveredPortals[index].Selected;
    }

    private void GoBack() => Navigation.NavigateTo("/");

    private void GoBackToInput()
    {
        _phase = Phase.Input;
        _discoveredPortals.Clear();
        _hasError = false;
        _errorMessage = null;
    }

    private void CreateAnother()
    {
        _phase = Phase.Input;
        _userInput = "";
        _discoveredPortals.Clear();
        _creationItems.Clear();
        _groupId = null;
        _watchIds.Clear();
        _creationCompleted = 0;
        _creationTotal = 0;
        _failedPortals = 0;
        _hasError = false;
        _errorMessage = null;
    }

    private void DismissError()
    {
        _hasError = false;
        _errorMessage = null;
    }

    private static string TruncateUrl(string url, int maxLength = 60)
    {
        if (string.IsNullOrEmpty(url) || url.Length <= maxLength)
            return url;
        return url[..maxLength] + "…";
    }

    private static string GetFriendlyErrorMessage(Exception ex, string context)
    {
        var baseMessage = ex switch
        {
            OperationCanceledException => "The operation was cancelled.",
            TimeoutException => "The operation timed out. The server may be busy.",
            HttpRequestException httpEx when httpEx.Message.Contains("refused") =>
                "Could not connect to the server. Please check if the service is running.",
            HttpRequestException => "Network error occurred. Please check your internet connection.",
            InvalidOperationException when ex.Message.Contains("not in a connected state") =>
                "Connection to server was lost. Please try refreshing the page.",
            _ => ex.Message
        };

        var suggestion = context switch
        {
            "connect" => " Try refreshing the page or check your network connection.",
            "stream" => " Try refreshing the page to continue.",
            _ => ""
        };

        return $"{baseMessage}{suggestion}";
    }

    // ── Disposal ──

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        await _cts.CancelAsync();

        if (_streamingTask is not null)
        {
            try
            {
                await _streamingTask.WaitAsync(TimeSpan.FromSeconds(2));
            }
            catch (TimeoutException) { }
            catch (OperationCanceledException) { }
            catch { }
        }

        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }

        _cts.Dispose();
    }

    // ── Types ──

    private enum Phase { Input, Discovery, Confirmation, Creating, Complete }
    private enum StepStatus { Pending, Active, Completed, Failed }

    private record ProgressStep(string Label, StepStatus Status, string? Detail = null);

    private class PortalSelection
    {
        public string Url { get; init; } = "";
        public string Name { get; init; } = "";
        public string? Platform { get; init; }
        public string? Reasoning { get; init; }
        public bool Recommended { get; init; }
        public bool Selected { get; set; }
    }

    // ── SignalR DTOs (mirror server-side records) ──

    private record GroupWatchProgress(
        string Phase,
        string Message,
        int? CompletedCount,
        int? TotalCount,
        List<DiscoveredPortalDto>? Portals,
        string? GroupId,
        List<string>? WatchIds);

    private record DiscoveredPortalDto(
        string Url,
        string Name,
        string? Platform,
        string? Reasoning,
        bool Recommended);

    private record ConfirmedPortalDto(
        string Url,
        string? Name,
        string? PlatformId,
        string? Reasoning);
}
