@page "/jobwatch"
@page "/jobwatch/setup"
@rendermode InteractiveAuto
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json
@using ChangeDetection.Shared.Dtos

<PageTitle>Job Watch Setup - Change Detection</PageTitle>

<div class="jobwatch-setup">
    <header class="page-header">
        <div class="header-content">
            <h1>🔬 Job Watch Setup</h1>
            <p class="subtitle">Configure automated monitoring of biotech job portals with profile-based matching</p>
        </div>
        @if (existingGroupId is not null)
        {
            <a href="/jobwatch/results" class="btn btn-outline btn-sm">← View Results</a>
        }
    </header>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
    }

    @if (isSeeded)
    {
        <div class="success-banner">
            <div class="success-icon">✅</div>
            <div class="success-content">
                <h3>Job Watch Project Created!</h3>
                <p>Monitoring @portalCount portals with your candidate profile. The system will check portals according to their configured schedule and alert you when matching jobs are found.</p>
                <div class="success-actions">
                    <a href="/jobwatch/results" class="btn btn-primary">View Results</a>
                    <a href="/" class="btn btn-outline">Go to Dashboard</a>
                </div>
            </div>
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner-sm"></div>
            <span>Loading configuration...</span>
        </div>
    }
    else
    {
        <div class="setup-layout">
            <div class="setup-main">
                <ProfileEditor @bind-ProfileJson="profileJson" OnChanged="OnProfileChanged" />
            </div>

            <aside class="setup-sidebar">
                <div class="sidebar-section">
                    <h3>Monitored Portals</h3>
                    <p class="sidebar-hint">@portalCount portals will be monitored across Prague and Copenhagen</p>

                    @if (portals.Count > 0)
                    {
                        <div class="portal-list">
                            @foreach (var portal in portals)
                            {
                                <div class="portal-item @portal.Tier">
                                    <div class="portal-info">
                                        <span class="portal-name">@portal.Name</span>
                                        <span class="portal-meta">@portal.CheckIntervalLabel · @(portal.NeedsJavaScript ? "JS" : "HTML")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline btn-sm" @onclick="LoadPortals">
                            Load portal list
                        </button>
                    }
                </div>

                <div class="sidebar-section">
                    @if (existingGroupId is not null)
                    {
                        <h3>Quick Links</h3>
                        <div class="quick-links">
                            <a href="/jobwatch/results" class="quick-link">📊 View Results Dashboard</a>
                            <a href="/" class="quick-link">🏠 Back to Dashboard</a>
                        </div>
                        <p class="sidebar-hint" style="margin-top: 0.75rem;">
                            Updating your profile automatically regenerates filter rules for all monitored portals.
                        </p>
                    }
                    else
                    {
                        <h3>How It Works</h3>
                        <div class="how-it-works">
                            <div class="step">
                                <span class="step-num">1</span>
                                <span>Define your candidate profile</span>
                            </div>
                            <div class="step">
                                <span class="step-num">2</span>
                                <span>System creates watches for all portals</span>
                            </div>
                            <div class="step">
                                <span class="step-num">3</span>
                                <span>Each scan extracts new job listings</span>
                            </div>
                            <div class="step">
                                <span class="step-num">4</span>
                                <span>LLM validates matches against your profile</span>
                            </div>
                            <div class="step">
                                <span class="step-num">5</span>
                                <span>You get alerts only for qualified matches</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="sidebar-section">
                    @if (existingGroupId is not null)
                    {
                        <button type="button" class="btn btn-primary btn-block"
                                disabled="@(isSubmitting || string.IsNullOrWhiteSpace(profileJson))"
                                @onclick="UpdateProfile">
                            @if (isSubmitting)
                            {
                                <span class="spinner-sm"></span>
                                <span>Updating profile...</span>
                            }
                            else
                            {
                                <span>✏️ Update Profile</span>
                            }
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary btn-block"
                                disabled="@(isSubmitting || string.IsNullOrWhiteSpace(profileJson))"
                                @onclick="CreateJobWatch">
                            @if (isSubmitting)
                            {
                                <span class="spinner-sm"></span>
                                <span>Creating project...</span>
                            }
                            else
                            {
                                <span>🚀 Create Job Watch Project</span>
                            }
                        </button>
                    }
                    @if (string.IsNullOrWhiteSpace(profileJson))
                    {
                        <p class="sidebar-hint">Fill in your profile to enable project creation</p>
                    }
                </div>
            </aside>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "groupId")]
    public string? GroupIdParam { get; set; }

    private string? profileJson;
    private string? errorMessage;
    private bool isSubmitting;
    private bool isSeeded;
    private bool isLoading = true;
    private int portalCount = 17;
    private List<PortalInfo> portals = [];
    private string? existingGroupId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!string.IsNullOrEmpty(GroupIdParam))
            {
                await LoadExistingGroup(GroupIdParam);
            }
            else
            {
                await AutoDetectExistingGroup();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load configuration: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AutoDetectExistingGroup()
    {
        try
        {
            var groups = await Http.GetFromJsonAsync<List<WatchGroupListItemDto>>("/api/groups");
            var jobGroup = groups?.FirstOrDefault(g => g.Tags.Contains("job-search"));
            if (jobGroup is not null)
            {
                await LoadExistingGroup(jobGroup.Id);
            }
        }
                catch (Exception ex)
        {
            // No existing group found — that's fine, show create mode
            Console.WriteLine($"[JobWatchSetup] Error in LoadExistingGroup: {ex.Message}");
        }
    }

    private async Task LoadExistingGroup(string groupId)
    {
        var response = await Http.GetAsync($"/api/groups/{groupId}");
        if (response.IsSuccessStatusCode)
        {
            var detail = await response.Content.ReadFromJsonAsync<WatchGroupDetailDto>();
            if (detail is not null)
            {
                existingGroupId = detail.Id;
                profileJson = detail.AnalysisProfileJson;
                // Auto-load portal list when editing existing group
                await LoadPortals();
            }
        }
    }

    private async Task LoadPortals()
    {
        try
        {
            var response = await Http.GetAsync("/api/jobwatch/portals");
            if (response.IsSuccessStatusCode)
            {
                portals = await response.Content.ReadFromJsonAsync<List<PortalInfo>>() ?? [];
                portalCount = portals.Count;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OnProfileChanged()
    {
        errorMessage = null;
    }

    private async Task UpdateProfile()
    {
        if (string.IsNullOrWhiteSpace(profileJson) || existingGroupId is null)
            return;

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var update = new WatchGroupUpdateDto { AnalysisProfileJson = profileJson };
            var response = await Http.PutAsJsonAsync($"/api/groups/{existingGroupId}", update);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/jobwatch/results");
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update profile: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task CreateJobWatch()
    {
        if (string.IsNullOrWhiteSpace(profileJson))
        {
            errorMessage = "Please fill in your candidate profile before creating the project.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new
            {
                ProfileJson = profileJson,
                UserIntent = "Monitor biotech/life-science job portals for matching positions based on candidate profile"
            };

            var response = await Http.PostAsJsonAsync("/api/jobwatch/seed", request);

            if (response.IsSuccessStatusCode)
            {
                isSeeded = true;
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create project: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class PortalInfo
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Tier { get; set; } = "";
        public double CheckIntervalHours { get; set; }
        public bool NeedsJavaScript { get; set; }

        public string CheckIntervalLabel => CheckIntervalHours switch
        {
            <= 24 => "Daily",
            <= 48 => "Every 2 days",
            _ => "Weekly"
        };
    }
}
