@using System.Net.Http.Json
@using ChangeDetection.Shared.Dtos
@inject HttpClient Http

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span class="brand-logo">
                <svg class="brand-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                    <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="2" opacity="0.5"/>
                    <circle cx="12" cy="12" r="2" fill="currentColor"/>
                    <path d="M12 2V6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path class="radar-sweep" d="M12 12L12 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            <span class="brand-text">Sentinel</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="1"/>
                        <rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="3" y="14" width="7" height="7" rx="1"/>
                        <rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                </span>
                Dashboard
            </NavLink>
        </div>

        @* Saved Views *@
        @if (views.Any())
        {
            <div class="nav-section-header px-3">
                <span>Views</span>
            </div>
            @foreach (var view in views)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link view-link" href="@($"/{view.Id}")">
                        <span class="view-icon" aria-hidden="true">@(view.Icon ?? "📋")</span> 
                        @view.Name
                        @if (view.IsBuiltIn)
                        {
                            <span class="built-in-badge" title="Built-in view">●</span>
                        }
                    </NavLink>
                </div>
            }
        }

        <div class="nav-section-header px-3">
            <span>Actions</span>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="watches/new">
                <span class="nav-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 8v8M8 12h8"/>
                    </svg>
                </span>
                Add Watch
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="settings">
                <span class="nav-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
                    </svg>
                </span>
                Settings
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private List<ViewDto> views = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadViews();
    }

    private async Task LoadViews()
    {
        try
        {
            views = await Http.GetFromJsonAsync<List<ViewDto>>("/api/views") ?? [];
        }
        catch
        {
            // Silent fail, views are optional
            views = [];
        }
    }
}

