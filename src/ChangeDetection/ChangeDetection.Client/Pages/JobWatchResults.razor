@page "/jobwatch/results"
@rendermode InteractiveAuto
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json
@using System.Text.Json.Serialization
@using ChangeDetection.Shared.Dtos

<PageTitle>Job Watch Results - Change Detection</PageTitle>

<div class="jobwatch-results">
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading job watch results...</span>
        </div>
    }
    else if (group is null)
    {
        <div class="empty-state">
            <div class="empty-icon">🔬</div>
            <h2>No Job Watch configured</h2>
            <p>Set up automated monitoring of biotech job portals with profile-based matching to get started.</p>
            <a href="/jobwatch/setup" class="btn btn-primary">Get Started</a>
        </div>
    }
    else
    {
        <header class="page-header">
            <div class="header-content">
                <h1>🔬 @group.Name</h1>
                <p class="subtitle">
                    Monitoring @group.Members.Count portals
                    @if (allChanges.Count > 0)
                    {
                        @if (llmUnavailable)
                        {
                            <span> · @allChanges.Count changes detected</span>
                        }
                        else
                        {
                            <span> · @allChanges.Count matches found</span>
                        }
                    }
                </p>
            </div>
            <div class="header-actions">
                <button class="btn btn-outline btn-sm" @onclick="RunAllChecks" disabled="@isRunningChecks">
                    @if (isRunningChecks)
                    {
                        <span class="spinner-sm"></span>
                        <span>Checking @checksCompleted/@group.Members.Count@(currentPortalName != null ? $" ({currentPortalName})" : "")...</span>
                    }
                    else
                    {
                        <span>▶ Run All Checks</span>
                    }
                </button>
                <a href="/jobwatch/setup?groupId=@group.Id" class="btn btn-outline btn-sm">⚙️ Edit Profile</a>
            </div>
        </header>

        @* Portal Health Status *@
        <div class="portal-status-bar">
            <span class="status-item status-ok" title="Active portals">
                ✅ @group.Members.Count(m => !m.HasErrors) active
            </span>
            @{ var errorCount = group.Members.Count(m => m.HasErrors); }
            @if (errorCount > 0)
            {
                <span class="status-item status-error" title="Portals with errors">
                    ⚠️ @errorCount errors
                </span>
            }
            @{ var unchecked_ = group.Members.Count(m => m.LastChecked == null); }
            @if (unchecked_ > 0)
            {
                <span class="status-item status-pending" title="Portals not yet checked">
                    ⏳ @unchecked_ pending
                </span>
            }
            @if (!string.IsNullOrEmpty(checkStatusMessage))
            {
                <span class="status-item status-message">@checkStatusMessage</span>
            }
        </div>

        @* Expandable portal detail *@
        <details class="portal-details">
            <summary class="portal-details-toggle">
                📡 Portal Status Details
            </summary>
            <div class="portal-list">
                @foreach (var m in group.Members.OrderBy(m => m.HasErrors ? 0 : 1).ThenBy(m => m.Name))
                {
                    <div class="portal-row @(m.HasErrors ? "portal-error" : "portal-ok")">
                        <span class="portal-status-icon">@(m.HasErrors ? "⚠️" : "✅")</span>
                        <span class="portal-name-cell">@m.Name</span>
                        <span class="portal-last-check">
                            @if (m.LastChecked.HasValue)
                            {
                                @FormatRelativeDate(m.LastChecked.Value)
                            }
                            else
                            {
                                <span class="pending-text">Not checked</span>
                            }
                        </span>
                    </div>
                }
            </div>
        </details>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error" role="alert">@errorMessage</div>
        }

        @if (llmUnavailable)
        {
            <div class="alert alert-warning" role="alert">
                @if (hasUnhealthyProviders)
                {
                    <p><strong>⚠️ LLM provider unhealthy</strong> - A configured provider has tripped its circuit breaker.</p>
                    <p>
                        Match scores show as 50% (default). <a href="/settings">Reset the provider</a>
                        in Settings after resolving the underlying issue.
                    </p>
                }
                else if (hasConfiguredProviders)
                {
                    <p><strong>⚠️ LLM scoring unavailable</strong> - Providers are configured but none could be reached.</p>
                    <p>
                        Match scores show as 50% (default). Check <a href="/settings">Settings</a>
                        to verify provider status.
                    </p>
                }
                else
                {
                    <p><strong>⚠️ No LLM provider configured</strong> - Configure a provider to enable scoring.</p>
                    <p>
                        Match scores show as 50% (default). Configure a provider in
                        <a href="/settings">Settings</a> to enable profile-based job matching.
                    </p>
                }
            </div>
        }

        @if (!llmUnavailable)
        {
            <div class="filter-bar">
                <button class="filter-btn @(activeFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
                    All <span class="filter-count">@allChanges.Count</span>
                </button>
                <button class="filter-btn @(activeFilter == "high" ? "active" : "")" @onclick='() => SetFilter("high")'>
                    High Match <span class="filter-count">@CountByTier("high")</span>
                </button>
                <button class="filter-btn @(activeFilter == "medium" ? "active" : "")" @onclick='() => SetFilter("medium")'>
                    Medium <span class="filter-count">@CountByTier("medium")</span>
                </button>
                <button class="filter-btn @(activeFilter == "low" ? "active" : "")" @onclick='() => SetFilter("low")'>
                    Low <span class="filter-count">@CountByTier("low")</span>
                </button>
            </div>

            <div class="filter-bar feedback-filter-bar">
                <button class="filter-btn @(feedbackFilter == "all" ? "active" : "")" @onclick='() => SetFeedbackFilter("all")'>
                    All Feedback <span class="filter-count">@CountByFeedback("all")</span>
                </button>
                <button class="filter-btn @(feedbackFilter == "liked" ? "active" : "")" @onclick='() => SetFeedbackFilter("liked")'>
                    👍 Liked <span class="filter-count">@CountByFeedback("liked")</span>
                </button>
                <button class="filter-btn @(feedbackFilter == "dismissed" ? "active" : "")" @onclick='() => SetFeedbackFilter("dismissed")'>
                    👎 Dismissed <span class="filter-count">@CountByFeedback("dismissed")</span>
                </button>
                <button class="filter-btn @(feedbackFilter == "unrated" ? "active" : "")" @onclick='() => SetFeedbackFilter("unrated")'>
                    Unrated <span class="filter-count">@CountByFeedback("unrated")</span>
                </button>
            </div>
        }
        else
        {
            <div class="filter-bar filter-bar-disabled">
                <span class="filter-disabled-note">Match scoring unavailable — configure an LLM provider in <a href="/settings">Settings</a></span>
            </div>
        }

        @if (filteredChanges.Count == 0)
        {
            <div class="no-results">
                @{
                    var checkedCount = group.Members.Count(m => m.LastChecked.HasValue);
                    var errCount = group.Members.Count(m => m.HasErrors);
                    var lastCheckTime = group.Members
                        .Where(m => m.LastChecked.HasValue)
                        .Select(m => m.LastChecked!.Value)
                        .DefaultIfEmpty()
                        .Max();
                }
                <p>
                    <strong>@checkedCount portals checked</strong>, 0 new listings detected.
                    @if (errCount > 0)
                    {
                        <span>@errCount portal(s) had errors.</span>
                    }
                    @if (lastCheckTime != default)
                    {
                        <span>Last check: @FormatRelativeDate(lastCheckTime).</span>
                    }
                </p>
                <p class="no-results-hint">
                    Portals are checked on their configured schedule (daily/weekly). 
                    Use <strong>▶ Run All Checks</strong> above to scan now, or check 
                    <strong>📡 Portal Status Details</strong> for per-portal health.
                </p>
            </div>
        }
        else
        {
            <div class="results-grid">
                @foreach (var item in filteredChanges)
                {
                    <div class="result-card @(item.Feedback == "Helpful" ? "card-liked" : "") @(item.Feedback is "FalsePositive" or "Irrelevant" ? "card-dismissed" : "")">
                        <div class="card-header">
                            <div class="card-title-row">
                                <h3 class="job-title">@item.PortalName</h3>
                                @if (!llmUnavailable)
                                {
                                    <span class="recommendation-badge badge-@item.Recommendation.ToLowerInvariant()">
                                        @item.Recommendation
                                    </span>
                                }
                            </div>
                            <span class="change-summary">@item.Title</span>
                            @if (llmUnavailable)
                            {
                                <span class="ai-badge" title="Scores are estimated — no LLM provider configured">⚠ AI unavailable</span>
                            }
                        </div>

                        <div class="card-body">
                            @if (item.Score.HasValue && !llmUnavailable)
                            {
                                <div class="score-row">
                                    <span class="score-label">Match</span>
                                    <div class="score-bar">
                                        <div class="score-fill score-@item.ScoreTier" style="width: @($"{item.Score.Value * 100:F0}%")"></div>
                                    </div>
                                    <span class="score-value">@($"{item.Score.Value * 100:F0}%")</span>
                                </div>
                            }

                            @if (item.Dimensions.Count > 0)
                            {
                                <div class="dimensions">
                                    @foreach (var dim in item.Dimensions)
                                    {
                                        <span class="dim-badge dim-@dim.Level" title="@dim.Name: @dim.Level">
                                            @dim.Icon @dim.Name
                                        </span>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(item.Reason))
                            {
                                <p class="reason-text">@item.Reason</p>
                            }

                            @if (item.Listings.Count > 0)
                            {
                                <div class="listing-stack">
                                    @foreach (var listing in item.Listings)
                                    {
                                        <article class="listing-card">
                                            <div class="listing-header">
                                                <div>
                                                    <h4 class="listing-title">@listing.Title</h4>
                                                    @if (!string.IsNullOrWhiteSpace(listing.Company))
                                                    {
                                                        <p class="listing-company">@listing.Company</p>
                                                    }
                                                </div>
                                                @if (!llmUnavailable && !string.IsNullOrWhiteSpace(listing.MatchAssessment))
                                                {
                                                    <span class="recommendation-badge listing-match badge-@GetListingAssessmentTier(listing.MatchAssessment)">
                                                        @GetListingAssessmentLabel(listing.MatchAssessment)
                                                    </span>
                                                }
                                            </div>

                                            <dl class="listing-meta">
                                                @if (!string.IsNullOrWhiteSpace(listing.Location))
                                                {
                                                    <div>
                                                        <dt>Location</dt>
                                                        <dd>@listing.Location</dd>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(listing.Deadline))
                                                {
                                                    <div>
                                                        <dt>Deadline</dt>
                                                        <dd>@FormatDeadline(listing.Deadline)</dd>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(listing.EducationRequired))
                                                {
                                                    <div>
                                                        <dt>Education</dt>
                                                        <dd>@listing.EducationRequired</dd>
                                                    </div>
                                                }
                                            </dl>

                                            @if (listing.KeySkills.Count > 0)
                                            {
                                                <div class="listing-skills">
                                                    @foreach (var skill in listing.KeySkills)
                                                    {
                                                        <span class="listing-skill">@skill</span>
                                                    }
                                                </div>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(listing.Url))
                                            {
                                                <a href="@listing.Url" target="_blank" rel="noopener noreferrer" class="listing-verify-link">Verify →</a>
                                            }
                                        </article>
                                    }
                                </div>
                            }
                        </div>

                        <div class="card-footer">
                            <span class="detected-date" title="@item.DetectedAt.ToString("yyyy-MM-dd HH:mm")">
                                @FormatRelativeDate(item.DetectedAt)
                            </span>
                            <div class="feedback-buttons">
                                <button class="feedback-btn liked @(item.Feedback == "Helpful" ? "active" : "")"
                                        title="Helpful — good match"
                                        disabled="@(feedbackSubmitting is not null)"
                                        @onclick="@(() => SubmitFeedback(item.ChangeId, "Helpful"))">
                                    👍
                                </button>
                                <button class="feedback-btn dismissed @(item.Feedback is "FalsePositive" or "Irrelevant" ? "active" : "")"
                                        title="Not relevant — hide this"
                                        disabled="@(feedbackSubmitting is not null)"
                                        @onclick="@(() => SubmitFeedback(item.ChangeId, "Irrelevant"))">
                                    👎
                                </button>
                            </div>
                            <a href="/changes/@item.ChangeId" class="detail-link">View details →</a>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private bool isRunningChecks;
    private int checksCompleted;
    private string? errorMessage;
    private string? checkStatusMessage;
    private string? currentPortalName;
    private bool llmUnavailable;
    private bool hasConfiguredProviders;
    private bool hasUnhealthyProviders;
    private WatchGroupDetailDto? group;
    private List<MatchResult> allChanges = [];
    private List<MatchResult> filteredChanges = [];
    private string activeFilter = "all";
    private string feedbackFilter = "all";
    private string? feedbackSubmitting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var groups = await Http.GetFromJsonAsync<List<WatchGroupListItemDto>>("/api/groups") ?? [];
            var jobGroup = groups.FirstOrDefault(g => g.Tags.Contains("job-search"));

            if (jobGroup is null)
            {
                isLoading = false;
                return;
            }

            var response = await Http.GetAsync($"/api/groups/{jobGroup.Id}");
            if (!response.IsSuccessStatusCode)
            {
                isLoading = false;
                return;
            }

            group = await response.Content.ReadFromJsonAsync<WatchGroupDetailDto>();
            if (group is null)
            {
                isLoading = false;
                return;
            }

            await LoadChanges();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load results: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadChanges()
    {
        if (group is null) return;

        var results = new List<MatchResult>();

        foreach (var member in group.Members)
        {
            try
            {
                var changes = await Http.GetFromJsonAsync<List<ChangeListItemDto>>(
                    $"/api/changes?watchId={member.WatchId}&limit=50") ?? [];

                foreach (var c in changes)
                {
                    var listings = ParseJobListings(c.ExtractedEntitiesJson);
                    results.Add(new MatchResult
                    {
                        ChangeId = c.Id,
                        Title = BuildHeadline(c.Summary, listings),
                        PortalName = member.Name ?? "Unknown portal",
                        DetectedAt = c.DetectedAt,
                        Score = c.RelevanceScore,
                        Reason = c.RelevanceReason,
                        Recommendation = ExtractRecommendation(c.RelevanceReason, c.RelevanceScore),
                        Dimensions = ParseDimensions(c.MatchDimensionsJson),
                        Listings = listings,
                        Feedback = c.Feedback
                    });
                }
            }
            catch
            {
                // Skip portal if changes can't be loaded
            }
        }

        allChanges = results.OrderByDescending(r => r.Score ?? 0).ThenByDescending(r => r.DetectedAt).ToList();

        // Detect if LLM scoring appears unavailable (fallback scores only, no dimensions)
        llmUnavailable = allChanges.Count > 0 &&
            allChanges.All(c => c.Score is null or 0.5f) &&
            allChanges.All(c => c.Dimensions.Count == 0);

        // Fetch provider status to differentiate no-provider vs unhealthy-provider
        if (llmUnavailable)
        {
            try
            {
                var providers = await Http.GetFromJsonAsync<List<LlmProviderDto>>("/api/llm/providers") ?? [];
                hasConfiguredProviders = providers.Count > 0;
                hasUnhealthyProviders = providers.Any(p => p.IsEnabled && !p.IsHealthy);
            }
            catch
            {
                // If we can't fetch provider status, fall back to generic message
            }
        }

        ApplyFilter();
    }

    private async Task RunAllChecks()
    {
        if (group is null || isRunningChecks) return;
        isRunningChecks = true;
        checksCompleted = 0;
        currentPortalName = null;
        checkStatusMessage = null;
        StateHasChanged();

        var errors = 0;
        var members = group.Members.ToList();
        const int batchSize = 4;

        // Run checks in parallel batches of 4
        for (var i = 0; i < members.Count; i += batchSize)
        {
            var batch = members.Skip(i).Take(batchSize).ToList();
            currentPortalName = string.Join(", ", batch.Select(m => m.Name?.Split(' ')[0] ?? "..."));
            StateHasChanged();
            await Task.Delay(1); // Allow UI to update

            var tasks = batch.Select(async member =>
            {
                try
                {
                    await Http.PostAsync($"/api/watches/{member.WatchId}/check", null);
                }
                catch
                {
                    Interlocked.Increment(ref errors);
                }
                Interlocked.Increment(ref checksCompleted);
            });

            await Task.WhenAll(tasks);
            StateHasChanged();
        }

        currentPortalName = null;

        // Reload group status and changes
        try
        {
            var response = await Http.GetAsync($"/api/groups/{group.Id}");
            if (response.IsSuccessStatusCode)
                group = await response.Content.ReadFromJsonAsync<WatchGroupDetailDto>();
            await LoadChanges();
        }
        catch { }

        checkStatusMessage = errors > 0
            ? $"Checks complete — {errors} portal(s) had errors"
            : "All checks complete";
        isRunningChecks = false;
        StateHasChanged();
    }

    private void SetFilter(string filter)
    {
        activeFilter = filter;
        ApplyFilter();
    }

    private void SetFeedbackFilter(string filter)
    {
        feedbackFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        IEnumerable<MatchResult> results = activeFilter switch
        {
            "high" => allChanges.Where(c => c.ScoreTier == "high"),
            "medium" => allChanges.Where(c => c.ScoreTier == "medium"),
            "low" => allChanges.Where(c => c.ScoreTier == "low"),
            _ => allChanges
        };

        filteredChanges = feedbackFilter switch
        {
            "liked" => results.Where(c => c.Feedback == "Helpful").ToList(),
            "dismissed" => results.Where(c => c.Feedback is "FalsePositive" or "Irrelevant").ToList(),
            "unrated" => results.Where(c => c.Feedback == "None").ToList(),
            _ => results.ToList()
        };
    }

    private int CountByTier(string tier) => allChanges.Count(c => c.ScoreTier == tier);

    private int CountByFeedback(string filter) => filter switch
    {
        "liked" => allChanges.Count(c => c.Feedback == "Helpful"),
        "dismissed" => allChanges.Count(c => c.Feedback is "FalsePositive" or "Irrelevant"),
        "unrated" => allChanges.Count(c => c.Feedback == "None"),
        _ => allChanges.Count
    };

    private async Task SubmitFeedback(string changeId, string feedback)
    {
        if (feedbackSubmitting is not null) return;
        feedbackSubmitting = changeId;
        StateHasChanged();

        try
        {
            var item = allChanges.FirstOrDefault(c => c.ChangeId == changeId);
            if (item is null) return;

            // Toggle: if same feedback already set, clear it
            var newFeedback = item.Feedback == feedback ? "None" : feedback;

            var response = await Http.PostAsJsonAsync($"/api/changes/{changeId}/feedback", new { Feedback = newFeedback, Note = (string?)null });
            if (response.IsSuccessStatusCode)
            {
                item.Feedback = newFeedback;
                ApplyFilter();
            }
        }
        catch { }
        finally
        {
            feedbackSubmitting = null;
            StateHasChanged();
        }
    }

    private static string BuildHeadline(string summary, List<JobListingInfo> listings)
    {
        if (listings.Count > 0)
        {
            var snippets = listings
                .Select(l => string.IsNullOrWhiteSpace(l.Company) ? l.Title : $"{l.Title} at {l.Company}")
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Take(3)
                .ToList();

            var headline = $"{listings.Count} new position{(listings.Count == 1 ? "" : "s")} found";
            if (snippets.Count > 0)
            {
                headline = $"{headline}: {string.Join(", ", snippets)}";
                if (listings.Count > snippets.Count)
                    headline = $"{headline}, +{listings.Count - snippets.Count} more";
            }

            return headline;
        }

        if (string.IsNullOrWhiteSpace(summary)) return "New change detected";
        var firstLine = summary.Split('\n', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? summary;
        return firstLine.Length > 80 ? firstLine[..77] + "..." : firstLine;
    }

    private static string ExtractRecommendation(string? reason, float? score)
    {
        // Extract recommendation from the bracket prefix: "[APPLY] reason..." or "[REVIEW] reason..."
        // Must use bracket format to avoid false matches (e.g., "apply immediately" in the text).
        if (!string.IsNullOrEmpty(reason) && reason.StartsWith('['))
        {
            var end = reason.IndexOf(']');
            if (end > 1)
            {
                var tag = reason[1..end].ToUpperInvariant();
                if (tag is "APPLY" or "REVIEW" or "SKIP") return tag;
            }
        }

        return score switch
        {
            >= 0.7f => "APPLY",
            >= 0.4f => "REVIEW",
            _ => "SKIP"
        };
    }

    private static List<DimensionInfo> ParseDimensions(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return [];

        try
        {
            using var doc = JsonDocument.Parse(json);
            var dims = new List<DimensionInfo>();

            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                var name = prop.Name;
                string level;
                if (prop.Value.ValueKind == JsonValueKind.Object)
                {
                    // Try to read a "score" or "match" field
                    if (prop.Value.TryGetProperty("score", out var scoreProp) && scoreProp.TryGetDouble(out var s))
                    {
                        level = s >= 0.7 ? "pass" : s >= 0.4 ? "partial" : "fail";
                    }
                    else if (prop.Value.TryGetProperty("match", out var matchProp))
                    {
                        var m = matchProp.GetString()?.ToLowerInvariant() ?? "";
                        level = m switch
                        {
                            "full" or "strong" or "yes" => "pass",
                            "partial" or "moderate" or "some" => "partial",
                            _ => "fail"
                        };
                    }
                    else
                    {
                        level = "partial";
                    }
                }
                else if (prop.Value.ValueKind == JsonValueKind.Number && prop.Value.TryGetDouble(out var numScore))
                {
                    level = numScore >= 0.7 ? "pass" : numScore >= 0.4 ? "partial" : "fail";
                }
                else if (prop.Value.ValueKind == JsonValueKind.String)
                {
                    var sv = prop.Value.GetString()?.ToLowerInvariant() ?? "";
                    level = sv switch
                    {
                        "full" or "strong" or "yes" or "pass" => "pass",
                        "partial" or "moderate" or "some" => "partial",
                        _ => "fail"
                    };
                }
                else
                {
                    level = "partial";
                }

                dims.Add(new DimensionInfo
                {
                    Name = FormatDimensionName(name),
                    Level = level,
                    Icon = level switch { "pass" => "✅", "partial" => "⚠️", _ => "❌" }
                });
            }

            return dims;
        }
        catch
        {
            return [];
        }
    }

    private static List<JobListingInfo> ParseJobListings(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return [];

        try
        {
            var listings = JsonSerializer.Deserialize<List<JobListingInfo>>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            return listings?
                .Where(l => !string.IsNullOrWhiteSpace(l.Title))
                .ToList() ?? [];
        }
        catch
        {
            return [];
        }
    }

    private static string FormatDimensionName(string name)
    {
        // Convert camelCase/snake_case to Title Case
        var result = System.Text.RegularExpressions.Regex.Replace(name, "([a-z])([A-Z])", "$1 $2");
        result = result.Replace('_', ' ');
        return System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(result.ToLowerInvariant());
    }

    private static string FormatRelativeDate(DateTime date)
    {
        // Treat stored dates as local time (server returns local DateTimes)
        var now = DateTime.Now;
        var diff = now - date;
        if (diff.TotalSeconds < 0) diff = TimeSpan.Zero; // Guard against clock skew
        var mins = (int)diff.TotalMinutes;
        var hours = (int)diff.TotalHours;
        var days = (int)diff.TotalDays;
        
        if (mins < 1) return "just now";
        if (mins < 60) return $"{mins}m ago";
        if (hours < 24) return $"{hours}h ago";
        if (days < 7) return $"{days}d ago";
        return date.ToString("MMM dd");
    }

    private static string FormatDeadline(string deadline)
    {
        return DateTime.TryParse(deadline, out var parsed)
            ? parsed.ToString("MMM dd, yyyy")
            : deadline;
    }

    private static string GetListingAssessmentTier(string? assessment)
    {
        var upper = assessment?.ToUpperInvariant() ?? "";
        if (upper.StartsWith("PASS"))
            return "apply";
        if (upper.StartsWith("SKIP"))
            return "skip";
        return "review";
    }

    private static string GetListingAssessmentLabel(string? assessment)
    {
        if (string.IsNullOrWhiteSpace(assessment))
            return "Review";

        var separator = assessment.IndexOf(" - ", StringComparison.Ordinal);
        return separator > 0 ? assessment[..separator] : assessment;
    }

    private class MatchResult
    {
        public string ChangeId { get; set; } = "";
        public string Title { get; set; } = "";
        public string PortalName { get; set; } = "";
        public DateTime DetectedAt { get; set; }
        public float? Score { get; set; }
        public string? Reason { get; set; }
        public string Recommendation { get; set; } = "REVIEW";
        public List<DimensionInfo> Dimensions { get; set; } = [];
        public List<JobListingInfo> Listings { get; set; } = [];
        public string Feedback { get; set; } = "None";

        public string ScoreTier
        {
            get
            {
                if (Score >= 0.7f) return "high";
                if (Score >= 0.4f) return "medium";
                return "low";
            }
        }
    }

    private class DimensionInfo
    {
        public string Name { get; set; } = "";
        public string Level { get; set; } = "partial";
        public string Icon { get; set; } = "⚠️";
    }

    private class JobListingInfo
    {
        [JsonPropertyName("title")]
        public string Title { get; set; } = "";

        [JsonPropertyName("company")]
        public string? Company { get; set; }

        [JsonPropertyName("location")]
        public string? Location { get; set; }

        [JsonPropertyName("deadline")]
        public string? Deadline { get; set; }

        [JsonPropertyName("education_required")]
        public string? EducationRequired { get; set; }

        [JsonPropertyName("key_skills")]
        public List<string> KeySkills { get; set; } = [];

        [JsonPropertyName("url")]
        public string? Url { get; set; }

        [JsonPropertyName("match_assessment")]
        public string? MatchAssessment { get; set; }
    }
}
