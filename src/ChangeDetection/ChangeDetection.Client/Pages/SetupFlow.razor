@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client
@using ChangeDetection.Shared.Dtos
@using ChangeDetection.Client.Components
@inject HttpClient Http
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Setup Watch - Change Detection</PageTitle>

<div class="flow-container">
    @* Header with back button and background option *@
    <header class="flow-header">
        <button class="back-button" @onclick="GoBack">
            <span class="icon">←</span> Back to Dashboard
        </button>
        <h1>Setting up your watch</h1>
        @if (_isProcessing && !_isComplete && !_hasError)
        {
            <button class="btn-background" @onclick="SendToBackground" title="Continue in background">
                <span class="icon">📤</span> Send to Background
            </button>
        }
    </header>

    @* Timeline section - history scrolls up, current state centered *@
    <div class="flow-main">
        <StateTimeline Entries="@_stateEntriesSnapshot" />
    </div>

    @* Input section - fixed at bottom when awaiting input *@
    @if (_awaitingInput && _currentQuestion is not null)
    {
        <div class="flow-input-container">
            <FlowInput Question="@_currentQuestion"
                       InputType="@_currentInputType"
                       Options="@_currentOptions"
                       OnResponse="HandleUserResponse"
                       IsProcessing="@_isProcessing" />
        </div>
    }

    @* Error state *@
    @if (_hasError)
    {
        <div class="flow-error">
            <div class="error-content">
                <span class="error-icon">⚠️</span>
                <p>@_errorMessage</p>
                <div class="error-actions">
                    <button class="btn-retry" @onclick="RetrySetup">Try Again</button>
                    <button class="btn-back" @onclick="GoBack">Back to Dashboard</button>
                </div>
            </div>
        </div>
    }

    @* Success state *@
    @if (_isComplete)
    {
        <div class="flow-success">
            <div class="success-content">
                <span class="success-icon">✅</span>
                <h2>Watch Created Successfully!</h2>
                <p>@_successMessage</p>
                <div class="success-actions">
                    <button class="btn-primary" @onclick="ViewWatch">View Watch</button>
                    <button class="btn-secondary" @onclick="CreateAnother">Create Another</button>
                </div>
            </div>
        </div>
    }

    @* Connection status - only show after first render (not during prerender) *@
    @if (_hasRendered && !_isConnected && !_hasError)
    {
        <div class="flow-connecting">
            <span class="spinner"></span>
            <span>Connecting...</span>
        </div>
    }

    @* Resuming indicator *@
    @if (_isResuming)
    {
        <div class="flow-resuming">
            <span class="spinner"></span>
            <span>Resuming session...</span>
        </div>
    }

    @* Empty state - no session and no input *@
    @if (_hasRendered && _isConnected && !_hasError && !_isComplete && !_isProcessing && !_awaitingInput && !_isResuming && _stateEntries.Count == 0)
    {
        <div class="flow-empty">
            <div class="empty-content">
                <span class="empty-icon">📝</span>
                <h2>No Input Provided</h2>
                <p>Paste a URL or describe what you want to watch to get started.</p>
                <button class="btn-primary" @onclick="GoBack">Go to Dashboard</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? SessionId { get; set; }

    private HubConnection? _hubConnection;
    private CancellationTokenSource _cts = new();
    private List<FlowStateEntry> _stateEntries = [];
    private bool _isConnected;
    private bool _isProcessing;
    private bool _awaitingInput;
    private bool _hasError;
    private bool _isComplete;
    private bool _isResuming;
    private bool _sentToBackground;
    private string? _errorMessage;
    private string? _successMessage;
    private Guid? _watchId;
    private Guid? _currentSessionId;

    // Current question state
    private string? _currentQuestion;
    private string? _currentInputType;
    private List<FlowOption>? _currentOptions;
    private bool _hasRendered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            await ConnectToHub();
            StateHasChanged();
        }
    }

    private async Task ConnectToHub()
    {
        var hubUrl = Navigation.ToAbsoluteUri("/hubs/setup").ToString();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .AddJsonProtocol(options =>
            {
                options.PayloadSerializerOptions.Converters.Add(new System.Text.Json.Serialization.JsonStringEnumConverter());
                options.PayloadSerializerOptions.PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase;
            })
            .Build();

        _hubConnection.On<FlowStateEntry>("ReceiveStateEntry", async (entry) => await OnStateEntryReceivedAsync(entry));
        _hubConnection.On<string>("ReceiveError", async (error) => await OnErrorReceivedAsync(error));
        _hubConnection.On<Guid, string>("SetupCompleted", async (watchId, summary) => await OnSetupCompletedAsync(watchId, summary));

        _hubConnection.Closed += async (error) =>
        {
            _isConnected = false;
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnected += async (connectionId) =>
        {
            _isConnected = true;
            await InvokeAsync(StateHasChanged);
        };

        try
        {
            await _hubConnection.StartAsync();
            _isConnected = true;

            // If SessionId is provided in the route, use it for page refresh resilience
            if (SessionId.HasValue)
            {
                await StartOrResumeWithSessionId(SessionId.Value);
            }
            // No session - show empty state (handled in UI)
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = $"Failed to connect: {ex.Message}";
        }

        StateHasChanged();
    }

    /// <summary>
    /// Start or resume a session with a pre-generated session ID.
    /// This enables page refresh resilience - if the user refreshes, we can resume the existing session.
    /// The server returns any pending input that should be processed.
    /// </summary>
    private async Task StartOrResumeWithSessionId(Guid sessionId)
    {
        if (_hubConnection is null || !_isConnected) return;

        _currentSessionId = sessionId;

        try
        {
            // Use the new hub method that supports pre-generated session IDs
            var response = await _hubConnection.InvokeAsync<StartSetupSessionResponse>("StartOrResumeSession", sessionId);

            // Check if there's pending input from the start-setup endpoint
            var inputToProcess = response.PendingInput;

            if (response.IsResumed && response.HasPipelineState)
            {
                // Session was resumed with existing pipeline state - recover state from hub
                _isResuming = true;
                StateHasChanged();
                await ResumeSession(sessionId);
                _isResuming = false;
            }
            else if (!string.IsNullOrEmpty(inputToProcess))
            {
                // Process the input (either from PendingInput or initialInput parameter)
                await StartProcessing(inputToProcess);
            }
            else if (response.IsResumed)
            {
                // Session exists, no pipeline state, no input - try to resume what we have
                _isResuming = true;
                StateHasChanged();
                await ResumeSession(sessionId);
                _isResuming = false;
            }
            // else: New session without input - empty state shown in UI
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = $"Failed to start session: {ex.Message}";
            _isProcessing = false;
            _isResuming = false;
        }

        StateHasChanged();
    }

    /// <summary>
    /// Start processing initial input with visual feedback.
    /// </summary>
    private async Task StartProcessing(string input)
    {
        _isProcessing = true;
        _stateEntries.Clear();
        _stateEntriesSnapshot = [];

        AddStateEntry(new FlowStateEntry
        {
            Stage = "Starting",
            Status = FlowStateStatus.InProgress,
            Summary = "Processing your request...",
            IsCurrentState = true
        });

        StateHasChanged();
        _ = StreamMessagesAsync(input);
    }

    private async Task ResumeSession(Guid sessionId)
    {
        if (_hubConnection is null || !_isConnected) return;

        _isProcessing = false;
        _currentSessionId = sessionId;

        try
        {
            // First, get the full state history from the hub
            var history = await _hubConnection.InvokeAsync<List<FlowStateEntryDto>?>("GetSessionHistory", sessionId);
            
            // Get current session state from hub
            var state = await _hubConnection.InvokeAsync<SetupSessionStateDto?>("GetSessionState", sessionId);
            
            if (state == null && (history == null || history.Count == 0))
            {
                // Session expired or not found - not an error, just need to start fresh
                _stateEntries.Clear();
                _stateEntriesSnapshot = [];
                return; // Empty state will be shown in UI
            }

            // Update UI with full history
            _stateEntries.Clear();
            _stateEntriesSnapshot = [];
            
            // Restore all history entries
            if (history != null && history.Count > 0)
            {
                foreach (var historyEntry in history)
                {
                    AddStateEntry(MapToFlowStateEntry(historyEntry));
                }
                
                // Check the last entry to determine current state
                var lastEntry = history[^1];
                if (lastEntry.Status == FlowStateStatusDto.Question)
                {
                    _awaitingInput = true;
                    _currentQuestion = lastEntry.Summary;
                    _currentInputType = lastEntry.InputType ?? "text";
                    _currentOptions = lastEntry.Options?.Select(o => new FlowOption(
                        o.Label,
                        o.Value,
                        o.IsRecommended,
                        o.Preview
                    )).ToList();
                }
                else if (lastEntry.Status == FlowStateStatusDto.Completed && lastEntry.Stage == "Complete")
                {
                    _isComplete = true;
                    _successMessage = lastEntry.Summary;
                    _watchId = lastEntry.WatchId;
                }
                else if (lastEntry.Status == FlowStateStatusDto.Failed)
                {
                    _hasError = true;
                    _errorMessage = lastEntry.Summary;
                }
                else if (lastEntry.Status is FlowStateStatusDto.InProgress 
                    or FlowStateStatusDto.Thinking 
                    or FlowStateStatusDto.Pending 
                    or FlowStateStatusDto.Recovery)
                {
                    // Session is actively processing - indicate this in the UI
                    _isProcessing = true;
                }
            }
            else if (state != null)
            {
                // No history but session exists - show current state only
                var prompt = state.CurrentPrompt ?? "Waiting for your response...";
                
                if (state.AwaitingInput)
                {
                    AddStateEntry(new FlowStateEntry
                    {
                        Stage = state.Stage,
                        Status = FlowStateStatus.Question,
                        Summary = prompt,
                        IsCurrentState = true,
                        InputType = "text"
                    });
                    
                    _awaitingInput = true;
                    _currentQuestion = prompt;
                    _currentInputType = "text";
                }
                else
                {
                    // Session is actively processing - indicate this in the UI
                    _isProcessing = true;
                    var stageDisplay = state.IsBackgrounded 
                        ? $"Processing in background: {state.Stage}" 
                        : "Processing...";
                    AddStateEntry(new FlowStateEntry
                    {
                        Stage = state.Stage,
                        Status = FlowStateStatus.InProgress,
                        Summary = stageDisplay,
                        IsCurrentState = true
                    });
                }
            }
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = $"Failed to resume session: {ex.Message}";
        }

        StateHasChanged();
    }

    private async Task StreamMessagesAsync(string input)
    {
        if (_hubConnection is null || _currentSessionId is null) return;

        try
        {
            var request = new SendSetupMessageRequest
            {
                SessionId = _currentSessionId.Value,
                Message = input
            };

            // Use StreamAsync with cancellation token to allow cleanup on dispose
            await foreach (var entry in _hubConnection.StreamAsync<FlowStateEntryDto>("SendMessage", request, _cts.Token))
            {
                await OnStateEntryReceivedAsync(MapToFlowStateEntry(entry));
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when component is disposed during streaming
        }
        catch (Exception ex)
        {
            _hasError = true;
            // Include exception type for debugging - helps identify the root cause
            _errorMessage = $"Error ({ex.GetType().Name}): {ex.Message}";
            _isProcessing = false;
            
            // Log to console for development debugging
            Console.WriteLine($"SetupFlow stream error: {ex}");
            
            await InvokeAsync(StateHasChanged);
        }
    }

    private static FlowStateEntry MapToFlowStateEntry(FlowStateEntryDto dto) => new()
    {
        Stage = dto.Stage,
        Status = dto.Status switch
        {
            FlowStateStatusDto.Pending => FlowStateStatus.Pending,
            FlowStateStatusDto.InProgress => FlowStateStatus.InProgress,
            FlowStateStatusDto.Thinking => FlowStateStatus.Thinking,
            FlowStateStatusDto.Completed => FlowStateStatus.Completed,
            FlowStateStatusDto.Failed => FlowStateStatus.Failed,
            FlowStateStatusDto.Question => FlowStateStatus.Question,
            FlowStateStatusDto.Recovery => FlowStateStatus.Recovery,
            _ => FlowStateStatus.Pending
        },
        Summary = dto.Summary,
        Details = dto.Details,
        Timestamp = dto.Timestamp,
        IsCurrentState = dto.IsCurrentState,
        InputType = dto.InputType,
        Options = dto.Options?.Select(o => new FlowOption(o.Label, o.Value, o.IsRecommended, o.Preview)).ToList(),
        WatchId = dto.WatchId
    };

    private async Task OnStateEntryReceivedAsync(FlowStateEntry entry)
    {
        // Mark previous current state as not current
        // Use a for loop to avoid modifying collection during enumeration
        for (var i = 0; i < _stateEntries.Count; i++)
        {
            if (_stateEntries[i].IsCurrentState)
            {
                // Create new entry with IsCurrentState = false
                _stateEntries[i] = _stateEntries[i] with { IsCurrentState = false };
            }
            
            // When any new progress arrives, mark ALL previous InProgress entries as Completed
            // (If we've moved on to a new step, the previous steps must have finished)
            // Exception: Thinking entries should stay as Thinking for proper grouping
            if (_stateEntries[i].Status == FlowStateStatus.InProgress)
            {
                _stateEntries[i] = _stateEntries[i] with { Status = FlowStateStatus.Completed };
            }
        }

        AddStateEntry(entry);

        // Check if we're awaiting input
        if (entry.Status == FlowStateStatus.Question)
        {
            _awaitingInput = true;
            _isProcessing = false;
            _currentQuestion = entry.Summary;
            _currentInputType = entry.InputType;
            _currentOptions = entry.Options;
        }
        else
        {
            _awaitingInput = false;
            _currentQuestion = null;
        }

        // Check for completion
        if (entry.Status == FlowStateStatus.Completed && entry.Stage == "Complete")
        {
            _isComplete = true;
            _successMessage = entry.Details ?? entry.Summary;
            _isProcessing = false;
        }
        // Check for error
        else if (entry.Status == FlowStateStatus.Failed)
        {
            _hasError = true;
            _errorMessage = entry.Details ?? entry.Summary;
            _isProcessing = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnErrorReceivedAsync(string error)
    {
        _hasError = true;
        _errorMessage = error;
        _isProcessing = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSetupCompletedAsync(Guid watchId, string summary)
    {
        _isComplete = true;
        _watchId = watchId;
        _successMessage = summary;
        _isProcessing = false;

        AddStateEntry(new FlowStateEntry
        {
            Stage = "Complete",
            Status = FlowStateStatus.Completed,
            Summary = "✓ Watch created successfully",
            IsCurrentState = true
        });

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleUserResponse(string response)
    {
        if (_hubConnection is null || _currentSessionId is null) return;

        _awaitingInput = false;
        _isProcessing = true;
        _currentQuestion = null;

        // Add user response to timeline
        AddStateEntry(new FlowStateEntry
        {
            Stage = "UserInput",
            Status = FlowStateStatus.Completed,
            Summary = $"You: {TruncateSummary(response)}",
            IsCurrentState = false
        });

        // Add processing entry
        AddStateEntry(new FlowStateEntry
        {
            Stage = "Processing",
            Status = FlowStateStatus.InProgress,
            Summary = "Processing your response...",
            IsCurrentState = true
        });

        StateHasChanged();

        try
        {
            // Stream results from the hub
            _ = StreamMessagesAsync(response);
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = $"Failed to send response: {ex.Message}";
            _isProcessing = false;
            StateHasChanged();
        }
    }

    // Snapshot for thread-safe rendering
    private List<FlowStateEntry> _stateEntriesSnapshot = [];

    private void AddStateEntry(FlowStateEntry entry)
    {
        _stateEntries.Add(entry);
        // Create a new snapshot for render to avoid concurrent modification
        _stateEntriesSnapshot = [.. _stateEntries];
    }

    private static string TruncateSummary(string text, int maxLength = 40)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private async Task SendToBackground()
    {
        if (_hubConnection is null || _currentSessionId is null) return;

        try
        {
            // Mark as sent to background so DisposeAsync doesn't end the session
            _sentToBackground = true;
            
            // Tell the server this session is going to the background
            await _hubConnection.SendAsync("SendToBackground", _currentSessionId.Value);
            
            // Navigate back to dashboard
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to send to background: {ex.Message}");
            // Still navigate away
            Navigation.NavigateTo("/");
        }
    }

    private void RetrySetup()
    {
        _hasError = false;
        _errorMessage = null;
        _stateEntries.Clear();
        _stateEntriesSnapshot = [];

        // Navigate back to dashboard - user can start fresh from there
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void ViewWatch()
    {
        if (_watchId.HasValue)
        {
            Navigation.NavigateTo($"/watches/{_watchId}");
        }
    }

    private void CreateAnother()
    {
        Navigation.NavigateTo("/");
    }

    public async ValueTask DisposeAsync()
    {
        // Cancel any ongoing streaming operations
        await _cts.CancelAsync();
        _cts.Dispose();

        if (_hubConnection is not null)
        {
            // Only end session if it wasn't sent to background and is still active
            // Sessions sent to background should continue processing
            if (_currentSessionId.HasValue && !_sentToBackground && !_isComplete)
            {
                try
                {
                    await _hubConnection.SendAsync("EndSession", _currentSessionId.Value);
                }
                catch { /* Ignore errors during cleanup */ }
            }

            await _hubConnection.DisposeAsync();
        }
    }
}
