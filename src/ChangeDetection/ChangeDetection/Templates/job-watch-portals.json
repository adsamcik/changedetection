          { "name": "title", "selector": "td:first-child a", "type": "String", "isRequired": true, "isIdentityField": true },
          { "name": "url", "selector": "td:first-child a", "type": "Url", "isRequired": true },
          { "name": "location", "selector": "td:nth-child(2)", "type": "String" },
          { "name": "category", "selector": "td:nth-child(3)", "type": "String" },
          { "name": "posted_date", "selector": "td:nth-child(4)", "type": "Date" }
        ],
        "identityFields": ["title", "location"],
        "_notes": "Old URL /search-results?keywords=... was deprecated and 404s as of Mar 2026. New URL /search/?q=...&locationsearch=Denmark returns filtered DK results (17 as of verification). Location column contains city + region (Måløv, Bagsværd, Gentofte, etc.)."
      }
    },
    {
      "id": "watch-novonesis",
