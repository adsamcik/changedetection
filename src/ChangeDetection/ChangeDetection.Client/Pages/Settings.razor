@page "/settings"
@rendermode InteractiveAuto
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LocalStorageService LocalStorage

<PageTitle>Settings - Change Detection</PageTitle>

<UnsavedChangesGuard IsDirty="@(isNotificationsDirty || isGeneralSettingsDirty)">
<div class="settings-page">
    <header class="settings-header">
        <h1>Settings</h1>
        <p class="subtitle">Configure LLM providers, notifications, and application settings</p>
        
        <div class="search-container">
            <div class="search-input-wrapper">
                <label for="settings-search" class="visually-hidden">Search settings</label>
                <span class="search-icon" aria-hidden="true">🔍</span>
                <input type="text"
                       id="settings-search"
                       class="search-input" 
                       placeholder="Search settings..." 
                       @bind="searchQuery" 
                       @bind:event="oninput"
                       @bind:after="OnSearchChanged" />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="search-clear" @onclick="ClearSearch" type="button" aria-label="Clear search">
                        <span aria-hidden="true">×</span>
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(searchQuery) && !matchingTabs.Any())
            {
                <div class="search-no-results">No results found for "@searchQuery"</div>
            }
        </div>
    </header>

    <div class="settings-tabs" role="tablist" aria-label="Settings sections">
        <button role="tab"
                id="tab-providers"
                aria-selected="@(activeTab == "providers")"
                aria-controls="panel-providers"
                class="tab @(activeTab == "providers" ? "active" : "") @GetTabDimmedClass("providers") @GetTabHighlightClass("providers")"
                @onclick="HandleSetProvidersTab">
            @GetHighlightedTabName("LLM Providers", "providers")
        </button>
        <button role="tab"
                id="tab-logs"
                aria-selected="@(activeTab == "logs")"
                aria-controls="panel-logs"
                class="tab @(activeTab == "logs" ? "active" : "") @GetTabDimmedClass("logs") @GetTabHighlightClass("logs")"
                @onclick="HandleSetLogsTab">
            @GetHighlightedTabName("LLM Logs", "logs")
        </button>
        <button role="tab"
                id="tab-notifications"
                aria-selected="@(activeTab == "notifications")"
                aria-controls="panel-notifications"
                class="tab @(activeTab == "notifications" ? "active" : "") @GetTabDimmedClass("notifications") @GetTabHighlightClass("notifications")"
                @onclick="HandleSetNotificationsTab">
            @GetHighlightedTabName("Notifications", "notifications")
        </button>
        <button role="tab"
                id="tab-general"
                aria-selected="@(activeTab == "general")"
                aria-controls="panel-general"
                class="tab @(activeTab == "general" ? "active" : "") @GetTabDimmedClass("general") @GetTabHighlightClass("general")"
                @onclick="HandleSetGeneralTab">
            @GetHighlightedTabName("General", "general")
        </button>
    </div>

    @if (activeTab == "providers")
    {
        <section id="panel-providers"
                 role="tabpanel"
                 aria-labelledby="tab-providers"
                 class="settings-section @GetSectionDimmedClass("providers")">
            <div class="section-header">
                <div>
                    <h2>LLM Provider Configuration</h2>
                    <p class="section-description">Configure AI providers for natural language processing. Providers are used in priority order with automatic fallback.</p>
                </div>
                <button class="btn btn-primary" @onclick="ShowAddProvider">+ Add Provider</button>
            </div>

            @if (isLoadingProviders)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                </div>
            }
            else
            {
                <div class="providers-list">
                    @foreach (var provider in providers.OrderBy(p => p.Priority))
                    {
                        <div class="provider-card @(provider.IsEnabled ? "" : "disabled") @(provider.IsHealthy ? "" : "unhealthy")">
                            <div class="provider-header">
                                <div class="provider-info">
                                    <span class="health-indicator @(provider.IsHealthy ? "healthy" : "unhealthy")"></span>
                                    <h3>@provider.ProviderType</h3>
                                    <span class="priority-badge">Priority @provider.Priority</span>
                                </div>
                                <div class="provider-actions">
                                    <button class="btn-icon" title="Move up" aria-label="Move provider up" @onclick="() => MoveProvider(provider, -1)" 
                                            disabled="@(provider.Priority <= 1)">⬆️</button>
                                    <button class="btn-icon" title="Move down" aria-label="Move provider down" @onclick="() => MoveProvider(provider, 1)">⬇️</button>
                                    <button class="btn-icon" title="Edit" aria-label="Edit provider" @onclick="() => EditProvider(provider)">✏️</button>
                                    <button class="btn-icon" title="@(provider.IsEnabled ? "Disable" : "Enable")" aria-label="@(provider.IsEnabled ? "Disable provider" : "Enable provider")"
                                            @onclick="() => ToggleProvider(provider)">
                                        @(provider.IsEnabled ? "🔴" : "🟢")
                                    </button>
                                    <button class="btn-icon danger" title="Delete" aria-label="Delete provider" @onclick="() => DeleteProvider(provider)">🗑️</button>
                                </div>
                            </div>
                            <div class="provider-details">
                                @if (!string.IsNullOrEmpty(provider.ModelId))
                                {
                                    <span class="detail">Model: @provider.ModelId</span>
                                }
                                @if (provider.MaxTokens > 0)
                                {
                                    <span class="detail">Max Tokens: @provider.MaxTokens</span>
                                }
                                <span class="detail">Cost: $@provider.CostPerInputToken.ToString("F6")/input, $@provider.CostPerOutputToken.ToString("F6")/output</span>
                            </div>
                            @if (!provider.IsHealthy)
                            {
                                <div class="provider-error">
                                    Circuit breaker open - provider temporarily unavailable
                                </div>
                            }
                        </div>
                    }

                    @if (!providers.Any())
                    {
                        <div class="empty-state">
                            <p>No LLM providers configured. Add a provider to enable natural language input processing.</p>
                        </div>
                    }
                </div>
            }

            <div class="usage-summary">
                <h3>Usage Statistics</h3>
                @if (usageStats != null)
                {
                    <div class="stats-grid">
                        <div class="stat-item">
                            <span class="stat-value">@usageStats.TotalRequests</span>
                            <span class="stat-label">Total Requests</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value">@usageStats.TotalInputTokens.ToString("N0")</span>
                            <span class="stat-label">Input Tokens</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value">@usageStats.TotalOutputTokens.ToString("N0")</span>
                            <span class="stat-label">Output Tokens</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value">$@usageStats.TotalCost.ToString("F4")</span>
                            <span class="stat-label">Total Cost</span>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
    else if (activeTab == "logs")
    {
        <section id="panel-logs"
                 role="tabpanel"
                 aria-labelledby="tab-logs"
                 class="settings-section @GetSectionDimmedClass("logs")">
            <div class="section-header">
                <div>
                    <h2>LLM Logs</h2>
                    <p class="section-description">View recent LLM operations for debugging. Logs show requests, responses, errors, and circuit breaker events.</p>
                </div>
                <div class="log-actions">
                    <button class="btn btn-outline" @onclick="RefreshLogs" disabled="@isLoadingLogs">
                        @if (isLoadingLogs)
                        {
                            <span class="spinner-small"></span>
                        }
                        else
                        {
                            <span>🔄 Refresh</span>
                        }
                    </button>
                    <button class="btn btn-outline danger" @onclick="ClearLogs">🗑️ Clear Logs</button>
                </div>
            </div>

            @if (isLoadingLogs)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                </div>
            }
            else if (llmLogs.Count == 0)
            {
                <div class="empty-state">
                    <p>No LLM logs available. Logs will appear here when LLM operations are performed.</p>
                </div>
            }
            else
            {
                <div class="log-filters">
                    <div class="filter-group">
                        <label>Filter by level:</label>
                        <select @bind="logLevelFilter" class="form-control-small">
                            <option value="">All Levels</option>
                            <option value="Error">Errors</option>
                            <option value="Warning">Warnings</option>
                            <option value="Info">Info</option>
                            <option value="Debug">Debug</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Filter by category:</label>
                        <select @bind="logCategoryFilter" class="form-control-small">
                            <option value="">All Categories</option>
                            <option value="Request">Requests</option>
                            <option value="Response">Responses</option>
                            <option value="Error">Errors</option>
                            <option value="CircuitBreaker">Circuit Breaker</option>
                            <option value="Retry">Retries</option>
                            <option value="Fallback">Fallbacks</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="checkbox-label compact">
                            <input type="checkbox" @bind="groupByRequest" />
                            <span>Group request/response</span>
                        </label>
                    </div>
                    <span class="log-count">Showing @FilteredLogs.Count() of @llmLogs.Count logs</span>
                </div>

                <div class="logs-list">
                    @if (groupByRequest)
                    {
                        @foreach (var group in GroupedLogs)
                        {
                            @if (group.IsGrouped)
                            {
                                <div class="log-entry log-group @group.StatusClass">
                                    <div class="log-header">
                                        <span class="log-level @group.StatusClass">@group.StatusLabel</span>
                                        <span class="log-category">Request/Response</span>
                                        <span class="log-provider">@group.ProviderName</span>
                                        @if (!string.IsNullOrEmpty(group.Model))
                                        {
                                            <span class="log-model">@group.Model</span>
                                        }
                                        <span class="log-timestamp">@group.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                                        @if (group.DurationMs.HasValue)
                                        {
                                            <span class="log-duration">@(group.DurationMs)ms</span>
                                        }
                                    </div>
                                    
                                    @if (group.HasError && group.Error != null)
                                    {
                                        <div class="log-error">
                                            <strong>Error:</strong> @group.Error.ErrorMessage
                                            @if (!string.IsNullOrEmpty(group.Error.ExceptionType))
                                            {
                                                <span class="exception-type">(@group.Error.ExceptionType)</span>
                                            }
                                        </div>
                                    }
                                    
                                    @if (group.InputTokens.HasValue || group.OutputTokens.HasValue)
                                    {
                                        <div class="log-tokens">
                                            @if (group.InputTokens.HasValue)
                                            {
                                                <span>Input: @group.InputTokens tokens</span>
                                            }
                                            @if (group.OutputTokens.HasValue)
                                            {
                                                <span>Output: @group.OutputTokens tokens</span>
                                            }
                                        </div>
                                    }
                                    
                                    <div class="log-group-details">
                                        @if (group.Request != null)
                                        {
                                            <details class="log-details">
                                                <summary>📤 Request</summary>
                                                <pre class="full-content">@group.Request.FullPrompt</pre>
                                            </details>
                                        }
                                        @if (group.Response != null)
                                        {
                                            <details class="log-details">
                                                <summary>📥 Response</summary>
                                                <pre class="full-content">@group.Response.FullResponse</pre>
                                            </details>
                                        }
                                        @if (group.Error?.StackTrace != null)
                                        {
                                            <details class="log-details">
                                                <summary>Stack Trace</summary>
                                                <pre class="stack-trace">@group.Error.StackTrace</pre>
                                            </details>
                                        }
                                    </div>
                                </div>
                            }
                            else if (group.Standalone != null)
                            {
                                var log = group.Standalone;
                                <div class="log-entry @GetLogLevelClass(log.Level)">
                                    <div class="log-header">
                                        <span class="log-level @GetLogLevelClass(log.Level)">@log.Level</span>
                                        <span class="log-category">@log.Category</span>
                                        <span class="log-provider">@log.ProviderName</span>
                                        @if (!string.IsNullOrEmpty(log.Model))
                                        {
                                            <span class="log-model">@log.Model</span>
                                        }
                                        <span class="log-timestamp">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                                        @if (log.DurationMs.HasValue)
                                        {
                                            <span class="log-duration">@(log.DurationMs)ms</span>
                                        }
                                    </div>
                                    <div class="log-message">@log.Message</div>
                                    @if (!string.IsNullOrEmpty(log.ErrorMessage))
                                    {
                                        <div class="log-error">
                                            <strong>Error:</strong> @log.ErrorMessage
                                            @if (!string.IsNullOrEmpty(log.ExceptionType))
                                            {
                                                <span class="exception-type">(@log.ExceptionType)</span>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(log.StackTrace))
                                    {
                                        <details class="log-details">
                                            <summary>Stack Trace</summary>
                                            <pre class="stack-trace">@log.StackTrace</pre>
                                        </details>
                                    }
                                </div>
                            }
                        }
                    }
                    else
                    {
                        @foreach (var log in FilteredLogs)
                        {
                            <div class="log-entry @GetLogLevelClass(log.Level)">
                                <div class="log-header">
                                    <span class="log-level @GetLogLevelClass(log.Level)">@log.Level</span>
                                    <span class="log-category">@log.Category</span>
                                    <span class="log-provider">@log.ProviderName</span>
                                    @if (!string.IsNullOrEmpty(log.Model))
                                    {
                                        <span class="log-model">@log.Model</span>
                                    }
                                    <span class="log-timestamp">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</span>
                                    @if (log.DurationMs.HasValue)
                                    {
                                        <span class="log-duration">@(log.DurationMs)ms</span>
                                    }
                                </div>
                                <div class="log-message">@log.Message</div>
                                @if (!string.IsNullOrEmpty(log.ErrorMessage))
                                {
                                    <div class="log-error">
                                        <strong>Error:</strong> @log.ErrorMessage
                                        @if (!string.IsNullOrEmpty(log.ExceptionType))
                                        {
                                            <span class="exception-type">(@log.ExceptionType)</span>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(log.PromptPreview))
                                {
                                    <details class="log-details">
                                        <summary>Prompt Preview</summary>
                                        <pre>@log.PromptPreview</pre>
                                    </details>
                                }
                                @if (!string.IsNullOrEmpty(log.FullPrompt))
                                {
                                    <details class="log-details">
                                        <summary>Full Prompt</summary>
                                        <pre class="full-content">@log.FullPrompt</pre>
                                    </details>
                                }
                                @if (!string.IsNullOrEmpty(log.ResponsePreview))
                                {
                                    <details class="log-details">
                                        <summary>Response Preview</summary>
                                        <pre>@log.ResponsePreview</pre>
                                    </details>
                                }
                                @if (!string.IsNullOrEmpty(log.FullResponse))
                                {
                                    <details class="log-details">
                                        <summary>Full Response</summary>
                                        <pre class="full-content">@log.FullResponse</pre>
                                    </details>
                                }
                                @if (!string.IsNullOrEmpty(log.StackTrace))
                                {
                                    <details class="log-details">
                                        <summary>Stack Trace</summary>
                                        <pre class="stack-trace">@log.StackTrace</pre>
                                    </details>
                                }
                                @if (log.InputTokens.HasValue || log.OutputTokens.HasValue)
                                {
                                    <div class="log-tokens">
                                        @if (log.InputTokens.HasValue)
                                        {
                                            <span>Input: @log.InputTokens tokens</span>
                                        }
                                        @if (log.OutputTokens.HasValue)
                                        {
                                            <span>Output: @log.OutputTokens tokens</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </section>
    }
    else if (activeTab == "notifications")
    {
        <section id="panel-notifications"
                 role="tabpanel"
                 aria-labelledby="tab-notifications"
                 class="settings-section @GetSectionDimmedClass("notifications")"
                  @oninput="MarkNotificationsDirty">
            <h2>Notification Settings</h2>
            <p class="section-description">Configure how you want to be notified when changes are detected.</p>

            @if (isLoadingNotifications)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(notificationMessage))
                {
                    <div class="@(notificationSuccess ? "success-message" : "error-message")">@notificationMessage</div>
                }

                <div class="settings-card">
                    <h3>Notification Channels</h3>
                    <p class="card-description">Set the default destinations used by pipeline Notify blocks and watches without custom notification targets.</p>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="notificationChannels.EmailEnabled" @bind:after="MarkNotificationsDirty" />
                                <span>Email</span>
                            </label>
                            <input type="email" @bind="notificationChannels.EmailAddress" class="form-control" placeholder="alerts@example.com" />
                        </div>
                        <div class="form-group">
                            <button class="btn btn-outline"
                                    type="button"
                                    disabled="@(!notificationChannels.EmailEnabled || string.IsNullOrWhiteSpace(notificationChannels.EmailAddress))"
                                    @onclick='() => TestNotificationChannel("Email", notificationChannels.EmailAddress)'>
                                Test Email
                            </button>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="notificationChannels.DiscordEnabled" @bind:after="MarkNotificationsDirty" />
                                <span>Discord webhook</span>
                            </label>
                            <input type="url" @bind="notificationChannels.DiscordWebhookUrl" class="form-control" placeholder="https://discord.com/api/webhooks/..." />
                        </div>
                        <div class="form-group">
                            <button class="btn btn-outline"
                                    type="button"
                                    disabled="@(!notificationChannels.DiscordEnabled || string.IsNullOrWhiteSpace(notificationChannels.DiscordWebhookUrl))"
                                    @onclick='() => TestNotificationChannel("Discord", notificationChannels.DiscordWebhookUrl)'>
                                Test Discord
                            </button>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="notificationChannels.WebhookEnabled" @bind:after="MarkNotificationsDirty" />
                                <span>Generic webhook</span>
                            </label>
                            <input type="url" @bind="notificationChannels.WebhookUrl" class="form-control" placeholder="https://hooks.example.com/notify" />
                        </div>
                        <div class="form-group">
                            <button class="btn btn-outline"
                                    type="button"
                                    disabled="@(!notificationChannels.WebhookEnabled || string.IsNullOrWhiteSpace(notificationChannels.WebhookUrl))"
                                    @onclick='() => TestNotificationChannel("Webhook", notificationChannels.WebhookUrl)'>
                                Test Webhook
                            </button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" @bind="notificationChannels.BrowserEnabled" @bind:after="MarkNotificationsDirty" />
                            <span>Browser (stored as preferred channel; server delivery is currently preview-only)</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <label for="defaultChannel">Default pipeline channel</label>
                        <select id="defaultChannel" class="form-control" @bind="notificationChannels.DefaultChannelName">
                            <option value="">Send to all enabled channels</option>
                            @foreach (var channel in AvailableNotificationChannels)
                            {
                                <option value="@channel.Value">@channel.Label</option>
                            }
                        </select>
                        <p class="form-hint">NotifyBlock instances without an explicit channel use this selection.</p>
                    </div>

                    <button class="btn btn-primary" @onclick="SaveNotificationChannels" disabled="@isSavingNotifications">
                        @if (isSavingNotifications)
                        {
                            <span class="spinner-small"></span>
                        }
                        Save Channel Settings
                    </button>
                </div>

                <div class="settings-card">
                    <h3>SMTP Delivery</h3>
                    <p class="card-description">Configure the SMTP server used for email notifications.</p>

                    <div class="form-group">
                        <label for="smtpHost">SMTP Host</label>
                        <input type="text" id="smtpHost" @bind="smtpHost" class="form-control" placeholder="smtp.example.com" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="smtpPort">SMTP Port</label>
                            <input type="number" id="smtpPort" @bind="smtpPort" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" @bind="smtpUseSsl" @bind:after="MarkNotificationsDirty" />
                                <span>Use SSL/TLS</span>
                            </label>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="smtpUsername">SMTP Username</label>
                        <input type="text" id="smtpUsername" @bind="smtpUsername" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label for="smtpPassword">SMTP Password</label>
                        <input type="password" id="smtpPassword" @bind="smtpPassword" class="form-control" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="fromEmail">From Email Address</label>
                            <input type="email" id="fromEmail" @bind="fromEmail" class="form-control" placeholder="noreply@example.com" />
                        </div>
                        <div class="form-group">
                            <label for="fromName">From Name</label>
                            <input type="text" id="fromName" @bind="fromName" class="form-control" placeholder="Change Detection" />
                        </div>
                    </div>

                    <button class="btn btn-primary" @onclick="SaveSmtpSettings" disabled="@isSavingNotifications">
                        @if (isSavingNotifications)
                        {
                            <span class="spinner-small"></span>
                        }
                        Save SMTP Settings
                    </button>
                </div>
            }
        </section>
    }
    else if (activeTab == "general")
    {
        <section id="panel-general"
                 role="tabpanel"
                 aria-labelledby="tab-general"
                 class="settings-section @GetSectionDimmedClass("general")"
                 @oninput="MarkGeneralSettingsDirty">
            <h2>General Settings</h2>
            
            @if (isLoadingGeneralSettings)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(generalSettingsMessage))
                {
                    <div class="@(generalSettingsSuccess ? "success-message" : "error-message")">@generalSettingsMessage</div>
                }
                
                <div class="settings-card">
                    <h3>Check Settings</h3>
                    <p class="card-description">Configure default behavior for website checks</p>
                    
                    <div class="form-group">
                        <label for="defaultInterval">Default Check Interval (minutes)</label>
                        <input type="number" id="defaultInterval" @bind="defaultCheckInterval" class="form-control" min="1" />
                        <p class="form-hint">Default interval for new watches. Minimum 1 minute.</p>
                    </div>

                    <div class="form-group">
                        <label for="maxConcurrent">Max Concurrent Checks</label>
                        <input type="number" id="maxConcurrent" @bind="maxConcurrentChecks" class="form-control" min="1" max="20" />
                        <p class="form-hint">Maximum number of watches to check simultaneously</p>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="maxRetries">Max Retry Attempts</label>
                            <input type="number" id="maxRetries" @bind="maxRetryAttempts" class="form-control" min="0" max="10" />
                            <p class="form-hint">Retries for failed checks (0 = no retries)</p>
                        </div>
                        <div class="form-group">
                            <label for="retryDelay">Retry Delay (seconds)</label>
                            <input type="number" id="retryDelay" @bind="retryDelaySeconds" class="form-control" min="5" />
                            <p class="form-hint">Wait time between retry attempts</p>
                        </div>
                    </div>
                </div>

                <div class="settings-card">
                    <h3>Fetching Settings</h3>
                    <p class="card-description">Configure default HTTP and browser settings</p>
                    
                    <div class="form-group">
                        <label for="fetchTimeout">Default Fetch Timeout (seconds)</label>
                        <input type="number" id="fetchTimeout" @bind="defaultFetchTimeoutSeconds" class="form-control" min="5" max="300" />
