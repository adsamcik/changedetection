@page "/"
@page "/{ViewId?}"
@rendermode InteractiveAuto
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using ChangeDetection.Shared.Dtos
@using ChangeDetection.Client.Components
@inject HttpClient Http
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Command Center - Change Detection</PageTitle>

<div class="command-center">
    <!-- Hero Add Watch Section -->
    <section class="add-watch-hero">
        <div class="hero-content">
            <h1 class="hero-title">Add a new web page change detection watch</h1>
            
            <div class="add-watch-form">
                <SmartInput Placeholder="https://... or describe what you want to watch" />

                @if (creationMessage is not null)
                {
                    <div class="alert @(creationIsError ? "alert-error" : "alert-success")">
                        @creationMessage
                        <button class="alert-dismiss" @onclick="ClearCreationMessage">✕</button>
                    </div>
                }
            </div>

            <p class="hero-hint">💡 Paste a URL or describe what you want to monitor in plain English</p>
        </div>
    </section>

    <!-- Top Bar -->
    <header class="cmd-bar">
        <div class="cmd-search">
            <span class="search-icon">🔍</span>
            <input type="text" placeholder="Filter watches..." @bind="searchText" @bind:event="oninput" />
        </div>

        <div class="cmd-actions">
            <button class="btn-cmd @(isBulkMode ? "active" : "")" @onclick="ToggleBulkMode" title="@(isBulkMode ? "Exit bulk edit mode" : "Enter bulk edit mode")">
                <span class="icon">☑️</span> @(isBulkMode ? "Done" : "Select")
            </button>
            <button class="btn-cmd" @onclick="RunAllChecks" disabled="@isCheckingAll">
                <span class="icon">@(isCheckingAll ? "⏳" : "▶")</span> Run All
            </button>
            <button class="btn-cmd" @onclick="GoToSettings">
                <span class="icon">⚙️</span>
            </button>
        </div>
    </header>

    <!-- Bulk Actions Bar (shown when in bulk mode with selections) -->
    @if (isBulkMode)
    {
        <div class="bulk-actions-bar">
            <div class="bulk-selection-info">
                <input type="checkbox" 
                       checked="@IsAllSelected" 
                       @onchange="ToggleSelectAll" 
                       title="Select all" />
                <span>@selectedWatchIds.Count selected</span>
            </div>
            <div class="bulk-actions">
                <button class="btn-bulk" @onclick="BulkEnable" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Enable selected watches">
                    <span class="icon">✓</span> Enable
                </button>
                <button class="btn-bulk" @onclick="BulkDisable" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Disable selected watches">
                    <span class="icon">⏸</span> Disable
                </button>
                <button class="btn-bulk" @onclick="BulkCheck" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Check selected watches now">
                    <span class="icon">▶</span> Check Now
                </button>
                <button class="btn-bulk btn-bulk-edit" @onclick="OpenBulkEditDialog" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Edit selected watches">
                    <span class="icon">✎</span> Edit
                </button>
                <button class="btn-bulk btn-bulk-danger" @onclick="BulkDelete" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Delete selected watches">
                    <span class="icon">🗑</span> Delete
                </button>
            </div>
            @if (bulkOperationMessage is not null)
            {
                <div class="bulk-message @(bulkOperationIsError ? "error" : "success")">
                    @bulkOperationMessage
                    <button class="dismiss-btn" @onclick="ClearBulkMessage">✕</button>
                </div>
            }
        </div>
    }

    <!-- Main Content Area -->
    <div class="cmd-main">
        <!-- Watch List Panel -->
        <div class="watch-panel">
            <div class="panel-toolbar">
                <div class="filter-group">
                    <button class="filter-chip @(activeStatusFilter == null && !changedRecentlyFilter ? "active" : "")" @onclick="() => SetFilter(null)">All</button>
                    <button class="filter-chip @(activeStatusFilter == "Active" ? "active" : "")" @onclick='() => SetFilter("Active")'>Active</button>
                    <button class="filter-chip @(activeStatusFilter == "Checking" ? "active" : "")" @onclick='() => SetFilter("Checking")'>Checking</button>
                    <button class="filter-chip @(activeStatusFilter == "Error" ? "active" : "")" @onclick='() => SetFilter("Error")'>Errors</button>
                    <button class="filter-chip @(changedRecentlyFilter ? "active" : "")" @onclick="ToggleChangedFilter">Changed Recently</button>
                </div>
                <div class="stats-summary">
                    <span>@watches.Count Total</span>
                    @if (pendingSetups.Any())
                    {
                        <span class="separator">|</span>
                        <span class="text-warning">@pendingSetups.Count Setting up</span>
                    }
                    @{
                        var checkingCount = watches.Count(w => w.Status == "Checking");
                    }
                    @if (checkingCount > 0)
                    {
                        <span class="separator">|</span>
                        <span class="text-info">@checkingCount Checking</span>
                    }
                    <span class="separator">|</span>
                    <span class="text-success">@watches.Count(w => w.Status == "Active") Active</span>
                    <span class="separator">|</span>
                    <span class="text-danger">@watches.Count(w => w.Status == "Error") Errors</span>
                </div>
            </div>

            <div class="data-grid-container">
                @if (isLoading)
                {
                    <div class="loading-state">Loading watches...</div>
                }
                else if (FilteredWatches.Any() || pendingSetups.Any())
                {
                    <table class="data-grid">
                        <thead>
                            <tr>
                                @if (isBulkMode)
                                {
                                    <th width="40" class="checkbox-cell">
                                        <input type="checkbox" 
                                               checked="@IsAllSelected" 
                                               @onchange="ToggleSelectAll" 
                                               title="Select all" />
                                    </th>
                                }
                                <th width="40">St</th>
                                <th>Name / URL</th>
                                <th width="120">Last Check</th>
                                <th width="120">Last Change</th>
                                <th>Tags</th>
                                <th width="120" class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Pending setup sessions appear first *@
                            @foreach (var setup in pendingSetups)
                            {
                                <tr class="grid-row pending-setup-row" @onclick="() => ResumeSetup(setup.SessionId)">
                                    @if (isBulkMode)
                                    {
                                        <td class="checkbox-cell" @onclick:stopPropagation>
                                            <!-- Pending setups are not selectable -->
                                        </td>
                                    }
                                    <td class="status-cell">
                                        <div class="status-indicator @(setup.IsProcessing ? "checking" : "pending")" title="@GetSetupStatusTitle(setup)">
                                            @if (!setup.IsProcessing && !string.IsNullOrEmpty(setup.CurrentPrompt))
                                            {
                                                <span class="needs-input-badge">!</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="name-cell">
                                        <div class="watch-title pending-title">
                                            <span class="pending-icon">@(setup.IsProcessing ? "⚙️" : "⏳")</span>
                                            @(setup.DisplayName ?? "New Watch")
                                            @if (!setup.IsProcessing && !string.IsNullOrEmpty(setup.CurrentPrompt))
                                            {
                                                <span class="needs-input-label">Needs input</span>
                                            }
                                            else if (setup.IsProcessing)
                                            {
                                                <span class="processing-label">Processing...</span>
                                            }
                                        </div>
                                        <div class="watch-url pending-prompt">@GetSetupStatusText(setup)</div>
                                    </td>
                                    <td class="meta-cell">
                                        <span class="text-muted">-</span>
                                    </td>
                                    <td class="meta-cell">
                                        <span class="text-muted">-</span>
                                    </td>
                                    <td class="tags-cell">
                                        <span class="tag-badge @GetSetupTagClass(setup)">@GetSetupTagText(setup)</span>
                                    </td>
                                    <td class="actions-cell" @onclick:stopPropagation>
                                        <button class="btn-icon btn-resume" title="@(setup.IsProcessing ? "View Progress" : "Resume Setup")" @onclick="() => ResumeSetup(setup.SessionId)">→</button>
                                        <button class="btn-icon btn-cancel" title="Cancel Setup" @onclick="() => CancelSetup(setup.SessionId)">✕</button>
                                    </td>
                                </tr>
                            }
                            @* Regular watches *@
                            @foreach (var watch in FilteredWatches)
                            {
                                <tr class="grid-row @(watch.HasRecentChanges ? "highlight-change" : "") @(selectedWatchIds.Contains(watch.Id) ? "selected" : "")" @onclick="() => OnRowClick(watch.Id)">
                                    @if (isBulkMode)
                                    {
                                        <td class="checkbox-cell" @onclick:stopPropagation>
                                            <input type="checkbox" 
                                                   checked="@selectedWatchIds.Contains(watch.Id)" 
                                                   @onchange="() => ToggleWatchSelection(watch.Id)" />
                                        </td>
                                    }
                                    <td class="status-cell">
                                        <div class="status-indicator @watch.Status.ToLower()" title="@watch.Status"></div>
                                    </td>
                                    <td class="name-cell">
                                        <div class="watch-title">@GetDisplayTitle(watch)</div>
                                        <div class="watch-url">@TruncateUrl(watch.Url)</div>
                                    </td>
                                    <td class="meta-cell">
                                        @if (watch.LastCheck.HasValue)
                                        {
                                            <span title="@watch.LastCheck">@FormatTimeAgo(watch.LastCheck.Value)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="meta-cell">
                                        @if (watch.LatestChangeAt.HasValue)
                                        {
                                            <span class="change-time" title="@watch.LatestChangeAt">@FormatTimeAgo(watch.LatestChangeAt.Value)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="tags-cell">
                                        @foreach (var tag in watch.Tags.Take(3))
                                        {
                                            <span class="tag-badge" style="background-color: @tag.Color">@tag.Name</span>
                                        }
                                        @if (watch.Tags.Count > 3)
                                        {
                                            <span class="tag-more">+@(watch.Tags.Count - 3)</span>
                                        }
                                    </td>
                                    <td class="actions-cell" @onclick:stopPropagation>
                                        <button class="btn-icon" title="Check Now" @onclick="() => TriggerCheck(watch.Id)">▶</button>
                                        <button class="btn-icon" title="Edit" @onclick="() => NavigateToEdit(watch.Id)">✎</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <span>No watches found.</span>
                        <span class="empty-hint">Use the form above to add your first watch.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar: Recent Activity -->
        <div class="sidebar-panel">
            <div class="panel-header">
                <h3>Recent Activity</h3>
            </div>
            <div class="activity-feed">
                @* Show watches currently being checked (from DB or SignalR) *@
                @foreach (var checking in GetCheckingWatches())
                {
                    <div class="feed-item processing" @onclick="() => NavigateToWatch(checking.Id)">
                        <div class="feed-icon processing-icon">⏳</div>
                        <div class="feed-content">
                            <div class="feed-title">@checking.Name</div>
                            <div class="feed-summary">Checking for changes...</div>
                            <div class="feed-time">@(checking.StartedAt.HasValue ? FormatTimeAgo(checking.StartedAt.Value) : "now")</div>
                        </div>
                    </div>
                }
                @* Then show recent changes *@
                @if (recentChanges.Any())
                {
                    @foreach (var change in recentChanges)
                    {
                        <div class="feed-item" @onclick="() => NavigateToChange(change.Id)">
                            <div class="feed-icon">@GetImportanceIcon(change.Importance)</div>
                            <div class="feed-content">
                                <div class="feed-title">@change.WatchTitle</div>
                                <div class="feed-summary">@TruncateSummary(change.Summary, 60)</div>
                                <div class="feed-time">@FormatTimeAgo(change.DetectedAt)</div>
                            </div>
                        </div>
                    }
                }
                else if (!GetCheckingWatches().Any())
                {
                    <div class="empty-feed">No recent activity</div>
                }
            </div>
        </div>
    </div>

</div>

@* Bulk Edit Dialog *@
@if (showBulkEditDialog)
{
    <div class="modal-overlay" @onclick="CloseBulkEditDialog">
        <div class="bulk-edit-dialog" @onclick:stopPropagation>
            <div class="dialog-header">
                <h2>Edit @selectedWatchIds.Count Watches</h2>
                <button class="dialog-close" @onclick="CloseBulkEditDialog">✕</button>
            </div>
            <div class="dialog-content">
                <div class="form-group">
                    <label>Add Tags</label>
                    <input type="text" 
                           class="form-control" 
                           placeholder="tag1, tag2, tag3" 
                           @bind="bulkEditModel.AddTags" />
                    <small class="form-hint">Comma-separated tags to add to all selected watches</small>
                </div>

                <div class="form-group">
                    <label>Remove Tags</label>
                    <input type="text" 
                           class="form-control" 
                           placeholder="tag1, tag2" 
                           @bind="bulkEditModel.RemoveTags" />
                    <small class="form-hint">Comma-separated tags to remove from all selected watches</small>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeCheckInterval" />
                        <span>Change check interval</span>
                    </label>
                    @if (bulkEditModel.ChangeCheckInterval)
                    {
                        <div class="interval-input">
                            <input type="number" 
                                   class="form-control" 
                                   min="1" 
                                   @bind="checkIntervalMinutes" />
                            <span>minutes</span>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeUseJavaScript" />
                        <span>Change JavaScript rendering</span>
                    </label>
                    @if (bulkEditModel.ChangeUseJavaScript)
                    {
                        <label class="checkbox-label sub-option">
                            <input type="checkbox" @bind="bulkEditModel.UseJavaScript" />
                            <span>Enable JavaScript rendering</span>
                        </label>
                    }
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeNotifications" />
                        <span>Change notifications</span>
                    </label>
                    @if (bulkEditModel.ChangeNotifications)
                    {
                        <label class="checkbox-label sub-option">
                            <input type="checkbox" @bind="bulkEditModel.NotificationsEnabled" />
                            <span>Enable notifications</span>
                        </label>
                    }
                </div>
            </div>
            <div class="dialog-footer">
                <button class="btn-secondary" @onclick="CloseBulkEditDialog">Cancel</button>
                <button class="btn-primary" @onclick="ApplyBulkEdit" disabled="@isBulkOperating">
                    @if (isBulkOperating)
                    {
                        <span>Applying...</span>
                    }
                    else
                    {
                        <span>Apply Changes</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? ViewId { get; set; }

    private List<WatchListItemDto> watches = [];
    private List<ChangeListItemDto> recentChanges = [];
    private List<PendingSetupDto> pendingSetups = [];
    private Dictionary<string, ProcessingActivity> activeProcessing = [];
    private bool isLoading = true;
    private string? error;
    private string? creationMessage;
    private bool creationIsError;

    // Bulk editing state
    private bool isBulkMode;
    private HashSet<string> selectedWatchIds = [];
    private bool isBulkOperating;
    private string? bulkOperationMessage;
    private bool bulkOperationIsError;
    private bool showBulkEditDialog;
    
    // Bulk edit form model
    private BulkEditModel bulkEditModel = new();

    private bool IsAllSelected => FilteredWatches.Any() && FilteredWatches.All(w => selectedWatchIds.Contains(w.Id));

    // Helper property for check interval input
    private int checkIntervalMinutes
    {
        get => (int)(bulkEditModel.CheckInterval?.TotalMinutes ?? 60);
        set => bulkEditModel.CheckInterval = TimeSpan.FromMinutes(value);
    }

    /// <summary>
    /// Represents a watch currently being checked.
    /// </summary>
    private record ProcessingActivity(string WatchId, string WatchName, DateTime StartedAt);

    /// <summary>
    /// Represents a watch being checked, for display in the activity feed.
    /// </summary>
    private record CheckingWatch(string Id, string Name, DateTime? StartedAt);

    /// <summary>
    /// Gets all watches currently being checked, combining SignalR updates with DB state.
    /// SignalR updates take precedence as they have more accurate timing.
    /// </summary>
    private IEnumerable<CheckingWatch> GetCheckingWatches()
    {
        // Track which watches are already in activeProcessing
        var signalRWatchIds = activeProcessing.Keys.ToHashSet();
        
        // Return SignalR-tracked watches first (they have accurate start times)
        foreach (var processing in activeProcessing.Values.OrderByDescending(p => p.StartedAt))
        {
            yield return new CheckingWatch(processing.WatchId, processing.WatchName, processing.StartedAt);
        }
        
        // Then add any watches from the API that have Checking status but aren't in SignalR yet
        // (e.g., checks that started before the page loaded)
        foreach (var watch in watches.Where(w => w.Status == "Checking" && !signalRWatchIds.Contains(w.Id)))
        {
            yield return new CheckingWatch(watch.Id, watch.Title ?? watch.Url, watch.LastCheck);
        }
    }

    // SignalR connection
    private HubConnection? hubConnection;

    // Filters
    private string? activeStatusFilter;
    private bool changedRecentlyFilter;
    private string searchText = "";

    // New fields
    private bool isCheckingAll;

    private IEnumerable<WatchListItemDto> FilteredWatches
    {
        get
        {
            var query = watches.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(w => 
                    (w.Title?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    w.Url.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    w.Tags.Any(t => t.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                );
            }

            if (changedRecentlyFilter)
            {
                query = query.Where(w => w.HasRecentChanges);
            }
            else if (activeStatusFilter != null)
            {
                query = query.Where(w => w.Status == activeStatusFilter);
            }

            return query.OrderByDescending(w => w.LastCheck);
        }
    }

    private void SetFilter(string? status)
    {
        activeStatusFilter = status;
        changedRecentlyFilter = false;
    }

    private void ToggleChangedFilter()
    {
        changedRecentlyFilter = !changedRecentlyFilter;
        activeStatusFilter = null;
    }

    private void NavigateToEdit(string watchId)
    {
        Navigation.NavigateTo($"/watches/{watchId}/edit");
    }

    protected override async Task OnInitializedAsync()
    {
        await InitializeSignalR();
        await LoadWatches();
        await LoadRecentChanges();
    }

    private async Task InitializeSignalR()
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{baseUri}/hubs/changes")
            .WithAutomaticReconnect()
            .AddJsonProtocol(options =>
            {
                options.PayloadSerializerOptions.Converters.Add(new System.Text.Json.Serialization.JsonStringEnumConverter());
                options.PayloadSerializerOptions.PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase;
            })
            .Build();

        hubConnection.On<object>("ChangeDetected", async (data) =>
        {
            await LoadRecentChanges();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<System.Text.Json.JsonElement>("WatchStatusChanged", async (data) =>
        {
            // Track processing events for Recent Activity
            var watchId = data.GetProperty("watchId").GetString() ?? data.GetProperty("watchId").GetGuid().ToString();
            var watchName = data.GetProperty("watchName").GetString() ?? "";
            var status = data.GetProperty("status").GetString() ?? "";
            
            if (status == "Checking")
            {
                // Watch is being checked - add to active processing
                activeProcessing[watchId] = new ProcessingActivity(watchId, watchName, DateTime.UtcNow);
            }
            else
            {
                // Check completed (success or error) - remove from active processing
                activeProcessing.Remove(watchId);
            }
            
            // Refresh watches to get updated status
            await LoadWatches();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<object>("WatchCreated", async (data) =>
        {
            // Refresh watches when a new watch is created
            await LoadWatches();
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<System.Text.Json.JsonElement>("SetupSessionUpdated", async (data) =>
        {
            // Handle setup session updates in real-time
            var sessionId = data.GetProperty("sessionId").GetGuid();
            var isCompleted = data.GetProperty("isCompleted").GetBoolean();
            var isCancelled = data.GetProperty("isCancelled").GetBoolean();
            
            if (isCompleted || isCancelled)
            {
                // Remove session from pending list
                pendingSetups.RemoveAll(s => s.SessionId == sessionId);
            }
            else
            {
                // Add or update session in pending list
                var displayName = data.GetProperty("displayName").GetString() ?? "New Watch";
                var isProcessing = data.GetProperty("isProcessing").GetBoolean();
                string? currentPrompt = null;
                if (data.TryGetProperty("currentPrompt", out var promptProp) && promptProp.ValueKind != System.Text.Json.JsonValueKind.Null)
                {
                    currentPrompt = promptProp.GetString();
                }
                
                string? currentStage = null;
                if (data.TryGetProperty("currentStage", out var stageProp) && stageProp.ValueKind != System.Text.Json.JsonValueKind.Null)
                {
                    currentStage = stageProp.GetString();
                }
                
                var existing = pendingSetups.FirstOrDefault(s => s.SessionId == sessionId);
                if (existing != null)
                {
                    existing.DisplayName = displayName;
                    existing.IsProcessing = isProcessing;
                    existing.CurrentPrompt = currentPrompt;
                    existing.CurrentStage = currentStage;
                    existing.LastActivityAt = DateTimeOffset.UtcNow;
                }
                else
                {
                    pendingSetups.Insert(0, new PendingSetupDto
                    {
                        SessionId = sessionId,
                        DisplayName = displayName,
                        IsProcessing = isProcessing,
                        CurrentPrompt = currentPrompt,
                        CurrentStage = currentStage,
                        CreatedAt = DateTimeOffset.UtcNow,
                        LastActivityAt = DateTimeOffset.UtcNow
                    });
                }
            }
            
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR connection failed: {ex.Message}");
        }
    }

    private async Task LoadWatches()
    {
        isLoading = true;
        error = null;
        StateHasChanged();

        try
        {
            // Load watches and pending setups in parallel
            var watchesTask = Http.GetAsync("/api/watches");
            var pendingTask = Http.GetFromJsonAsync<List<PendingSetupDto>>("/api/llm/pending-setups");

            await Task.WhenAll(watchesTask, pendingTask);

            var response = await watchesTask;
            if (response.IsSuccessStatusCode)
            {
                watches = await response.Content.ReadFromJsonAsync<List<WatchListItemDto>>() ?? [];
            }
            else
            {
                error = "Failed to load watches.";
            }

            pendingSetups = await pendingTask ?? [];
        }
        catch (Exception ex)
        {
            error = $"Error loading watches: {ex.Message}";
            pendingSetups = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadRecentChanges()
    {
        try
        {
            recentChanges = await Http.GetFromJsonAsync<List<ChangeListItemDto>>("/api/changes?limit=10") ?? [];
        }
        catch
        {
            recentChanges = [];
        }
    }

    // New Methods for Redesign
    private void GoToSettings() => Navigation.NavigateTo("/settings");

    private void ClearCreationMessage()
    {
        creationMessage = null;
        creationIsError = false;
    }

    private async Task RunAllChecks()
    {
        if (isCheckingAll) return;
        isCheckingAll = true;
        StateHasChanged();

        try
        {
            // Trigger check for all enabled watches
            // Note: This might be heavy if there are many watches. Ideally backend should have a "Check All" endpoint.
            // For now, we trigger them individually in parallel.
            var tasks = watches.Where(w => w.IsEnabled).Select(w => TriggerCheck(w.Id));
            await Task.WhenAll(tasks);
        }
        finally
        {
            isCheckingAll = false;
            StateHasChanged();
        }
    }

    private int GetChangesTodayCount() => recentChanges.Count(c => c.DetectedAt.Date == DateTime.Today);
    
    private string GetAvgCheckDuration() => "5 s"; // Mock

    private int GetActiveWatchesCount() => watches.Count(w => w.IsEnabled);

    private int GetSuccessRate()
    {
        if (!watches.Any()) return 0;
        var successCount = watches.Count(w => w.Status != "Error");
        return (int)((double)successCount / watches.Count * 100);
    }

    private static string GetSetupStatusTitle(PendingSetupDto setup)
    {
        if (setup.IsProcessing) return "Processing";
        return "Awaiting input";
    }

    private static string GetSetupStatusText(PendingSetupDto setup)
    {
        if (!string.IsNullOrEmpty(setup.CurrentPrompt))
            return setup.CurrentPrompt;
        if (setup.IsProcessing)
            return "Analyzing page...";
        return "Setting up...";
    }

    private static string GetSetupTagClass(PendingSetupDto setup)
    {
        if (setup.IsProcessing) return "processing-tag";
        return "pending-tag";
    }

    private static string GetSetupTagText(PendingSetupDto setup)
    {
        if (setup.IsProcessing) return "Processing";
        return "Setting up";
    }

    private void ResumeSetup(Guid sessionId)
    {
        Navigation.NavigateTo($"/setup/{sessionId}");
    }

    private async Task CancelSetup(Guid sessionId)
    {
        try
        {
            await Http.DeleteAsync($"/api/llm/sessions/{sessionId}");
            pendingSetups.RemoveAll(s => s.SessionId == sessionId);
            StateHasChanged();
        }
        catch
        {
            // Just remove from local list - session will expire eventually
            pendingSetups.RemoveAll(s => s.SessionId == sessionId);
            StateHasChanged();
        }
    }
