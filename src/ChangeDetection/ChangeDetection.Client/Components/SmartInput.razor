@inject NavigationManager Navigation

<div class="smart-input-container">
    <div class="input-wrapper">
        <textarea @ref="_inputElement"
                  @bind="InputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="@Placeholder"
                  class="smart-input"
                  rows="2" />
    </div>

    @if (!string.IsNullOrEmpty(InputText))
    {
        <div class="mode-indicator">
            <span>✨ Press Enter to start setup</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Placeholder { get; set; } = "Paste a URL or describe what you want to watch...";

    private ElementReference _inputElement;
    private string _inputText = "";

    private string InputText
    {
        get => _inputText;
        set => _inputText = value;
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            return ProcessInput();
        }
        else if (e.Key == "Escape")
        {
            _inputText = "";
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task ProcessInput()
    {
        if (string.IsNullOrWhiteSpace(_inputText))
            return Task.CompletedTask;

        var trimmedInput = _inputText.Trim();
        
        // Immediately navigate to the setup flow - no HTTP call, no timeout
        // The setup flow handles everything via SignalR streaming
        var encodedInput = Uri.EscapeDataString(trimmedInput);
        Navigation.NavigateTo($"/setup?input={encodedInput}");
        
        return Task.CompletedTask;
    }
}
