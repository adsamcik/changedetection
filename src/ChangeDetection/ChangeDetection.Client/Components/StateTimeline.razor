@using ChangeDetection.Shared.Dtos

<div class="state-timeline" role="log" aria-live="polite" aria-label="Setup progress timeline">
    @if (Entries.Count == 0)
    {
        <div class="timeline-empty" aria-label="Waiting for setup to begin">
            <span class="empty-icon" aria-hidden="true">🔄</span>
            <span>Waiting to start...</span>
        </div>
    }
    else
    {
        @* Render entries, grouping thinking entries together *@
        var processedEntries = ProcessEntries(Entries);
        @foreach (var item in processedEntries)
        {
            @if (item.IsThinkingGroup)
            {
                <div class="timeline-entry thinking @(item.IsExpanded ? "expanded" : "collapsed")" role="group" aria-label="AI thinking step">
                    <span class="timeline-icon" aria-hidden="true">💭</span>
                    <div class="timeline-content">
                        <button class="thinking-toggle" 
                                @onclick="@(() => ToggleThinking(item.ThinkingKey ?? ""))"
                                aria-expanded="@(item.IsExpanded ? "true" : "false")"
                                aria-controls="thinking-@item.ThinkingKey?.GetHashCode()">
                            <span class="toggle-icon" aria-hidden="true">@(item.IsExpanded ? "▼" : "▶")</span>
                            <span class="thinking-label">AI Thinking (@item.ThinkingStep)...</span>
                        </button>
                        @if (item.IsExpanded)
                        {
                            <div class="thinking-content" id="thinking-@item.ThinkingKey?.GetHashCode()">
                                <span class="thinking-text">@item.ThinkingContent</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="timeline-entry @GetStatusClass(item.Entry!.Status) @(item.Entry.IsCurrentState ? "current" : "")" 
                     role="listitem"
                     aria-current="@(item.Entry.IsCurrentState ? "step" : null)">
                    <span class="timeline-icon" aria-hidden="true">@GetStatusIcon(item.Entry.Status)</span>
                    <div class="timeline-content">
                        <span class="timeline-summary">@item.Entry.Summary</span>
                        @if (!string.IsNullOrEmpty(item.Entry.Details) && item.Entry.Status is FlowStateStatus.Failed or FlowStateStatus.Recovery)
                        {
                            <span class="timeline-details">@TruncateDetails(item.Entry.Details)</span>
                        }
                    </div>
                    <span class="timeline-time">@FormatTime(item.Entry.Timestamp)</span>
                </div>
            }
        }
    }
</div>

@code {
    [Parameter] public List<FlowStateEntry> Entries { get; set; } = [];
    
    private HashSet<string> _expandedThinking = [];

    private void ToggleThinking(string thinkingKey)
    {
        if (_expandedThinking.Contains(thinkingKey))
            _expandedThinking.Remove(thinkingKey);
        else
            _expandedThinking.Add(thinkingKey);
    }

    private List<TimelineItem> ProcessEntries(List<FlowStateEntry> entries)
    {
        var result = new List<TimelineItem>();
        var thinkingGroups = new Dictionary<string, List<FlowStateEntry>>();
        
        foreach (var entry in entries)
        {
            if (entry.Status == FlowStateStatus.Thinking)
            {
                // Group thinking entries by stage+step
                var key = $"{entry.Stage}:{entry.Details}";
                if (!thinkingGroups.ContainsKey(key))
                {
                    thinkingGroups[key] = [];
                    // Add placeholder for this thinking group in order
                    result.Add(new TimelineItem 
                    { 
                        IsThinkingGroup = true, 
                        Stage = entry.Stage,
                        ThinkingStep = entry.Details ?? "thinking",
                        ThinkingKey = key
                    });
                }
                thinkingGroups[key].Add(entry);
            }
            else
            {
                result.Add(new TimelineItem { Entry = entry });
            }
        }
        
        // Fill in thinking content for each group
        foreach (var item in result.Where(r => r.IsThinkingGroup))
        {
            if (thinkingGroups.TryGetValue(item.ThinkingKey!, out var thinkingEntries))
            {
                item.ThinkingContent = string.Concat(thinkingEntries.Select(e => e.Summary));
                item.IsExpanded = _expandedThinking.Contains(item.ThinkingKey!);
            }
        }
        
        return result;
    }

    private class TimelineItem
    {
        public bool IsThinkingGroup { get; set; }
        public FlowStateEntry? Entry { get; set; }
        public string? Stage { get; set; }
        public string? ThinkingStep { get; set; }
        public string? ThinkingKey { get; set; }
        public string? ThinkingContent { get; set; }
        public bool IsExpanded { get; set; }
    }

    private static string GetStatusIcon(FlowStateStatus status) => status switch
    {
        FlowStateStatus.InProgress => "→",
        FlowStateStatus.Thinking => "💭",
        FlowStateStatus.Completed => "✓",
        FlowStateStatus.Failed => "✗",
        FlowStateStatus.Recovery => "⟳",
        FlowStateStatus.Question => "❓",
        _ => "•"
    };

    private static string GetStatusClass(FlowStateStatus status) => status switch
    {
        FlowStateStatus.InProgress => "in-progress",
        FlowStateStatus.Thinking => "thinking",
        FlowStateStatus.Completed => "completed",
        FlowStateStatus.Failed => "failed",
        FlowStateStatus.Recovery => "recovery",
        FlowStateStatus.Question => "question",
        _ => ""
    };

    private static string TruncateDetails(string details, int maxLength = 50)
    {
        if (string.IsNullOrEmpty(details) || details.Length <= maxLength)
            return details;
        return details[..maxLength] + "...";
    }

    private static string FormatTime(DateTimeOffset timestamp)
    {
        var elapsed = DateTimeOffset.UtcNow - timestamp;
        
        if (elapsed.TotalSeconds < 5)
            return "now";
        if (elapsed.TotalSeconds < 60)
            return $"{(int)elapsed.TotalSeconds}s ago";
        if (elapsed.TotalMinutes < 60)
            return $"{(int)elapsed.TotalMinutes}m ago";
        
        return timestamp.ToLocalTime().ToString("HH:mm");
    }

    /// <summary>
    /// Creates a summary one-liner for a pipeline stage.
    /// Called by the hub to generate user-friendly summaries.
    /// </summary>
    public static string CreateStageSummary(string stage, string? detail = null) => stage switch
    {
        "UrlExtraction" when detail != null => $"URL: {TruncateUrl(detail)}",
        "UrlExtraction" => "Extracting URL...",
        "ContentFetching" => "Fetching page content...",
        "ContentAnalysis" when detail != null => $"Page type: {detail}",
        "ContentAnalysis" => "Analyzing content...",
        "SelectorGeneration" when detail != null => $"{detail} selectors generated",
        "SelectorGeneration" => "Generating selectors...",
        "SelectorValidation" => "Validating selectors...",
        "Recovery" when detail != null => $"Troubleshooting: {TruncateDetails(detail)}",
        "Recovery" => "Attempting recovery...",
        "Confirmation" => "Ready for confirmation",
        "Complete" => "Watch created successfully",
        "Failed" when detail != null => $"Failed: {TruncateDetails(detail)}",
        "Failed" => "Setup failed",
        "Starting" => "Processing your request...",
        "Resuming" => "Resuming your session...",
        "Processing" => "Processing your response...",
        "UserInput" when detail != null => $"You: {TruncateDetails(detail)}",
        "UserInput" => "Your response",
        _ => stage
    };

    private static string TruncateUrl(string url, int maxLength = 35)
    {
        if (string.IsNullOrEmpty(url) || url.Length <= maxLength)
            return url;
        
        // Try to keep the domain visible
        try
        {
            var uri = new Uri(url);
            var domain = uri.Host;
            if (domain.Length < maxLength - 3)
            {
                return domain + "/...";
            }
        }
                catch (Exception ex)
        {
            /* Ignore URI parsing errors */
            Console.WriteLine($"[StateTimeline] Error in TruncateUrl: {ex.Message}");
        }
        
        return url[..maxLength] + "...";
    }
}
