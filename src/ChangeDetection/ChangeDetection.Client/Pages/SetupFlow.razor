@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client
@using ChangeDetection.Shared.Dtos
@using ChangeDetection.Client.Components
@inject HttpClient Http
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Setup Watch - Change Detection</PageTitle>

<div class="flow-container">
    @* Header with back button *@
    <header class="flow-header">
        <button class="back-button" @onclick="GoBack" aria-label="Go back to dashboard">
            <span class="icon" aria-hidden="true">←</span> Back to Dashboard
        </button>
        <h1>Setting up your watch</h1>
    </header>

    @* Timeline section - history scrolls up, current state centered *@
    <div class="flow-main">
        <StateTimeline Entries="@_stateEntriesSnapshot" />
    </div>

    @* Input section - fixed at bottom when awaiting input *@
    @if (_awaitingInput && _currentQuestion is not null)
    {
        <div class="flow-input-container">
            <FlowInput Question="@_currentQuestion"
                       InputType="@_currentInputType"
                       Options="@_currentOptions"
                       OnResponse="HandleUserResponse"
                       IsProcessing="@_isProcessing" />
        </div>
    }

    @* Error state *@
    @if (_hasError)
    {
        <div class="flow-error" role="alertdialog" aria-modal="true" aria-labelledby="error-title" aria-describedby="error-message">
            <div class="error-content">
                <span class="error-icon" aria-hidden="true">⚠️</span>
                <p id="error-title" class="visually-hidden">Error occurred</p>
                <p id="error-message" role="alert">@_errorMessage</p>
                <div class="error-actions">
                    <button class="btn-retry" @onclick="RetrySetup">Try Again</button>
                    <button class="btn-back" @onclick="GoBack">Back to Dashboard</button>
                </div>
            </div>
        </div>
    }

    @* Success state *@
    @if (_isComplete)
    {
        <div class="flow-success" role="dialog" aria-modal="true" aria-labelledby="success-title" aria-describedby="success-message">
            <div class="success-content">
                <span class="success-icon" aria-hidden="true">✅</span>
                <h2 id="success-title">Watch Created Successfully!</h2>
                <p id="success-message">@_successMessage</p>
                <div class="success-actions">
                    <button class="btn-primary" @onclick="ViewWatch">View Watch</button>
                    <button class="btn-secondary" @onclick="CreateAnother">Create Another</button>
                </div>
            </div>
        </div>
    }

    @* Connection status - only show after first render (not during prerender) *@
    @if (_hasRendered && !_isConnected && !_hasError)
    {
        <div class="flow-connecting" role="status" aria-live="polite">
            <span class="spinner" aria-hidden="true"></span>
            <span>Connecting...</span>
        </div>
    }

    @* Reconnecting indicator *@
    @if (_isReconnecting)
    {
        <div class="flow-reconnecting" role="status" aria-live="polite">
            <span class="spinner" aria-hidden="true"></span>
            <span>Connection lost. Reconnecting...</span>
        </div>
    }

    @* Empty state - no session and no input *@
    @if (_hasRendered && _isConnected && !_hasError && !_isComplete && !_isProcessing && !_awaitingInput && _stateEntries.Count == 0)
    {
        <div class="flow-empty">
            <div class="empty-content">
                <span class="empty-icon">📝</span>
                <h2>No Input Provided</h2>
                <p>Paste a URL or describe what you want to watch to get started.</p>
                <button class="btn-primary" @onclick="GoBack">Go to Dashboard</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid? SessionId { get; set; }
    [Parameter] public string? Input { get; set; }

    private HubConnection? _hubConnection;
    private CancellationTokenSource _cts = new();
    private List<FlowStateEntry> _stateEntries = [];
    private bool _isConnected;
    private bool _isReconnecting;
    private bool _isProcessing;
    private bool _awaitingInput;
    private bool _hasError;
    private bool _isComplete;
    private bool _disposed;
    private string? _errorMessage;
    private string? _successMessage;
    private Guid? _watchId;
    private string? _currentSessionId;
    private Task? _streamingTask;

    // Current question state
    private string? _currentQuestion;
    private string? _currentInputType;
    private List<FlowOption>? _currentOptions;
    private bool _hasRendered;

    // Track which checkpoint we're at for routing user responses
    private SetupPhaseDto? _currentCheckpointPhase;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;

            // Only connect to hub if we have input to process
            if (!string.IsNullOrWhiteSpace(Input))
            {
                await ConnectToHub();
            }

            StateHasChanged();
        }
    }

    private async Task ConnectToHub()
    {
        var hubUrl = Navigation.ToAbsoluteUri("/hubs/composable-setup").ToString();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .AddJsonProtocol(options =>
            {
                options.PayloadSerializerOptions.Converters.Add(new System.Text.Json.Serialization.JsonStringEnumConverter());
                options.PayloadSerializerOptions.PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase;
            })
            .Build();

        _hubConnection.Closed += async (error) =>
        {
            _isConnected = false;
            _isReconnecting = false;
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnecting += async (error) =>
        {
            _isConnected = false;
            _isReconnecting = true;
            await InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnected += async (connectionId) =>
        {
            _isConnected = true;
            _isReconnecting = false;
            _hasError = false;
            _errorMessage = null;
            await InvokeAsync(StateHasChanged);
        };

        try
        {
            using var connectionCts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            await _hubConnection.StartAsync(connectionCts.Token);
            _isConnected = true;

            // Input was pre-routed by SmartInput — URLs come here, NL goes to /groupwatch
            if (!string.IsNullOrWhiteSpace(Input))
            {
                await StartComposableSetup(Input);
            }
        }
        catch (OperationCanceledException ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "connect");
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "connect");
        }

        StateHasChanged();
    }

    /// <summary>
    /// Start the composable setup pipeline by streaming from ComposableSetupHub.StartSetup.
    /// </summary>
    private async Task StartComposableSetup(string userInput)
    {
        _isProcessing = true;
        _stateEntries.Clear();
        _stateEntriesSnapshot = [];

        AddStateEntry(new FlowStateEntry
        {
            Stage = "Starting",
            Status = FlowStateStatus.InProgress,
            Summary = "Processing your request...",
            IsCurrentState = true
        });

        StateHasChanged();
        _streamingTask = StreamStartSetupAsync(userInput);
    }

    private async Task StreamStartSetupAsync(string userInput)
    {
        if (_hubConnection is null) return;

        try
        {
            await foreach (var progress in _hubConnection.StreamAsync<SetupProgressDto>("StartSetup", userInput, _cts.Token))
            {
                // Capture session ID from the first progress that includes it
                if (progress.SessionId is not null)
                {
                    _currentSessionId = progress.SessionId;
                }

                await OnSetupProgressReceivedAsync(progress);
            }

            // Stream completed without a checkpoint or error — mark as done if not already
            if (!_awaitingInput && !_hasError && !_isComplete)
            {
                _isProcessing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when component is disposed during streaming
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "stream");
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StreamConfirmIntentAsync(bool confirmed, string? feedback)
    {
        if (_hubConnection is null || _currentSessionId is null) return;

        try
        {
            await foreach (var progress in _hubConnection.StreamAsync<SetupProgressDto>(
                "ConfirmIntent", _currentSessionId, confirmed, feedback, _cts.Token))
            {
                await OnSetupProgressReceivedAsync(progress);
            }

            if (!_awaitingInput && !_hasError && !_isComplete)
            {
                _isProcessing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "stream");
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StreamConfirmPipelineAsync(bool confirmed, string? feedback)
    {
        if (_hubConnection is null || _currentSessionId is null) return;

        try
        {
            await foreach (var progress in _hubConnection.StreamAsync<SetupProgressDto>(
                "ConfirmPipeline", _currentSessionId, confirmed, feedback, _cts.Token))
            {
                await OnSetupProgressReceivedAsync(progress);
            }

            if (!_awaitingInput && !_hasError && !_isComplete)
            {
                _isProcessing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "stream");
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// Maps a SetupProgressDto from the composable hub into a FlowStateEntry for the timeline,
    /// and handles checkpoint / completion / error transitions.
    /// </summary>
    private async Task OnSetupProgressReceivedAsync(SetupProgressDto progress)
    {
        if (_disposed) return;

        var entry = MapFromSetupProgress(progress);

        // Mark previous current states as not current, previous InProgress as Completed
        for (var i = 0; i < _stateEntries.Count; i++)
        {
            if (_stateEntries[i].IsCurrentState)
            {
                _stateEntries[i] = _stateEntries[i] with { IsCurrentState = false };
            }
            if (_stateEntries[i].Status == FlowStateStatus.InProgress)
            {
                _stateEntries[i] = _stateEntries[i] with { Status = FlowStateStatus.Completed };
            }
        }

        AddStateEntry(entry);

        // Handle checkpoint: show confirmation UI
        if (progress.Type == SetupProgressTypeDto2.CheckpointReached)
        {
            _currentCheckpointPhase = progress.Phase;
            _awaitingInput = true;
            _isProcessing = false;

            if (progress.Phase == SetupPhaseDto.Checkpoint1 && progress.Intent is not null)
            {
                _currentQuestion = $"{progress.Message}\n\n" +
                    $"🔗 URL: {progress.Intent.Url}\n" +
                    $"📋 Intent: {progress.Intent.Intent}\n" +
                    $"📊 Change type: {progress.Intent.ChangeType}";
                _currentInputType = null;
                _currentOptions =
                [
                    new("✅ Looks good, proceed!", "confirm", IsRecommended: true),
                    new("✏️ Let me refine this", "modify")
                ];
            }
            else if (progress.Phase == SetupPhaseDto.Checkpoint2 && progress.Proposal is not null)
            {
                var isEmptyExtractionWarning = progress.Message.Contains("extracted no data", StringComparison.OrdinalIgnoreCase);
                var proposalDetail = progress.Proposal.HumanSummary;
                if (progress.Proposal.DryRun is not null)
                {
                    proposalDetail += progress.Proposal.DryRun.Success
                        ? $"\n\n✅ Dry run passed ({progress.Proposal.DryRun.ExecutionDurationMs}ms)"
                        : $"\n\n⚠️ Dry run failed: {progress.Proposal.DryRun.Error}";
                }
                if (progress.Proposal.QcValidation is not null)
                {
                    proposalDetail += progress.Proposal.QcValidation.Valid
                        ? "\n✅ QC validation passed"
                        : $"\n⚠️ QC issues: {string.Join(", ", progress.Proposal.QcValidation.Issues)}";
                }

                _currentQuestion = $"{progress.Message}\n\n{proposalDetail}";
                _currentInputType = null;
                _currentOptions = isEmptyExtractionWarning
                    ?
                    [
                        new("✏️ Make changes", "modify", IsRecommended: true),
                        new("Create anyway (may not work)", "confirm")
                    ]
                    :
                    [
                        new("✅ Create this watch!", "confirm", IsRecommended: true),
                        new("✏️ Make changes", "modify")
                    ];
            }
            else
            {
                _currentQuestion = progress.Message;
                _currentInputType = null;
                _currentOptions =
                [
                    new("Confirm", "confirm", IsRecommended: true),
                    new("Cancel", "cancel")
                ];
            }
        }
        // Handle completion
        else if (progress.Type == SetupProgressTypeDto2.Completed && progress.WatchId.HasValue)
        {
            _isComplete = true;
            _watchId = progress.WatchId;
            _successMessage = progress.Detail ?? progress.Message;
            _isProcessing = false;
            _awaitingInput = false;
        }
        // Handle failure
        else if (progress.Type == SetupProgressTypeDto2.Failed)
        {
            _hasError = true;
            _errorMessage = progress.Error ?? progress.Message;
            _isProcessing = false;
            _awaitingInput = false;
        }
        else
        {
            _awaitingInput = false;
            _currentQuestion = null;
        }

        if (!_disposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private static FlowStateEntry MapFromSetupProgress(SetupProgressDto progress) => new()
    {
        Stage = progress.Phase.ToString(),
        Status = progress.Type switch
        {
            SetupProgressTypeDto2.Started => FlowStateStatus.InProgress,
            SetupProgressTypeDto2.Thinking => FlowStateStatus.Thinking,
            SetupProgressTypeDto2.Progress => FlowStateStatus.InProgress,
            SetupProgressTypeDto2.CheckpointReached => FlowStateStatus.Question,
            SetupProgressTypeDto2.Completed => FlowStateStatus.Completed,
            SetupProgressTypeDto2.Failed => FlowStateStatus.Failed,
            _ => FlowStateStatus.Pending
        },
        Summary = progress.Message,
        Details = progress.Detail ?? progress.Error,
        IsCurrentState = true,
        WatchId = progress.WatchId
    };

    private async Task HandleUserResponse(string response)
    {
        if (_isProcessing || _hubConnection is null || _currentSessionId is null) return;

        _awaitingInput = false;
        _isProcessing = true;
        _currentQuestion = null;

        // Add user response to timeline
        AddStateEntry(new FlowStateEntry
        {
            Stage = "UserInput",
            Status = FlowStateStatus.Completed,
            Summary = $"You: {TruncateSummary(response)}",
            IsCurrentState = false
        });

        AddStateEntry(new FlowStateEntry
        {
            Stage = "Processing",
            Status = FlowStateStatus.InProgress,
            Summary = "Processing your response...",
            IsCurrentState = true
        });

        StateHasChanged();

        try
        {
            var confirmed = response is "confirm" or "yes";
            string? feedback = confirmed ? null : response;
            // "modify" means not confirmed with no specific feedback yet — 
            // the user may type custom feedback via FlowInput's "Type something else..." option.
            // If response is neither confirm nor a known action, treat it as custom feedback.
            if (response is "modify" or "cancel")
            {
                confirmed = false;
                feedback = response == "cancel" ? null : null;
            }
            else if (response is not "confirm" and not "yes")
            {
                confirmed = false;
                feedback = response;
            }

            if (_currentCheckpointPhase == SetupPhaseDto.Checkpoint1)
            {
                _streamingTask = StreamConfirmIntentAsync(confirmed, feedback);
            }
            else if (_currentCheckpointPhase == SetupPhaseDto.Checkpoint2)
            {
                _streamingTask = StreamConfirmPipelineAsync(confirmed, feedback);
            }
            else
            {
                _hasError = true;
                _errorMessage = "Unexpected checkpoint state. Please try again.";
                _isProcessing = false;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = GetFriendlyErrorMessage(ex, "send");
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // Snapshot for thread-safe rendering
    private List<FlowStateEntry> _stateEntriesSnapshot = [];

    private void AddStateEntry(FlowStateEntry entry)
    {
        _stateEntries.Add(entry);
        _stateEntriesSnapshot = [.. _stateEntries];
    }

    private static string TruncateSummary(string text, int maxLength = 40)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private void RetrySetup()
    {
        _hasError = false;
        _errorMessage = null;
        _stateEntries.Clear();
        _stateEntriesSnapshot = [];
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void ViewWatch()
    {
        if (_watchId.HasValue)
        {
            Navigation.NavigateTo($"/watches/{_watchId}");
        }
    }

    private void CreateAnother()
    {
        Navigation.NavigateTo("/");
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        await _cts.CancelAsync();

        if (_streamingTask is not null)
        {
            try
            {
                await _streamingTask.WaitAsync(TimeSpan.FromSeconds(2));
            }
            catch (TimeoutException) { }
            catch (OperationCanceledException) { }
            catch { }
        }

        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }

        _cts.Dispose();
    }

    /// <summary>
    /// Generates user-friendly error messages with recovery suggestions.
    /// </summary>
    private static string GetFriendlyErrorMessage(Exception ex, string context)
    {
        var baseMessage = ex switch
        {
            OperationCanceledException => "The operation was cancelled.",
            TimeoutException => "The operation timed out. The server may be busy.",
            HttpRequestException httpEx when httpEx.Message.Contains("refused") => 
                "Could not connect to the server. Please check if the service is running.",
            HttpRequestException => "Network error occurred. Please check your internet connection.",
            InvalidOperationException when ex.Message.Contains("not in a connected state") => 
                "Connection to server was lost. Please try refreshing the page.",
            _ => ex.Message
        };

        var suggestion = context switch
        {
            "connect" => " Try refreshing the page or check your network connection.",
            "session" => " The session may have expired. Try starting a new setup.",
            "send" => " Please wait a moment and try again.",
            "stream" => " Try refreshing the page to continue.",
            _ => ""
        };

        return $"{baseMessage}{suggestion}";
    }
}
