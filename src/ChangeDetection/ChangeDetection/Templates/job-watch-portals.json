{
  "templateId": "job-watch-biotech",
  "templateVersion": 1,
  "portals": [
    {
      "id": "watch-ucph",
      "name": "University of Copenhagen Vacancies",
      "description": "Lab/research roles in Faculty of Health, BRIC, NNF Center at UCPH",
      "url": "https://employment.ku.dk/all-vacancies/",
      "tier": "tier-1",
      "checkIntervalHours": 24,
      "extraTags": ["denmark", "academia"],
      "fetchSettings": {
        "useJavaScript": true,
        "timeoutSeconds": 30,
        "waitAfterLoadMs": 3000,
        "waitForSelector": "table.vacancies"
      },
      "schema": {
        "itemSelector": "table.vacancies tbody tr.vacancy-specs",
        "fields": [
          { "name": "title", "selector": "td:first-child a", "type": "String", "isRequired": true, "isIdentityField": true },
          { "name": "url", "selector": "td:first-child a", "type": "Url", "isRequired": true },
          { "name": "faculty", "selector": "td:nth-child(2)", "type": "String", "isIdentityField": true },
          { "name": "department", "selector": "td:nth-child(3)", "type": "String" },
          { "name": "deadline", "selector": "td:nth-child(4)", "type": "Date" }
        ],
        "identityFields": ["title", "faculty"],
        "_notes": "DataTable shows 10/94 by default. UseJavaScript=true required. Pipeline should ideally expand pagination to 100 via JS interaction. Column 3 is department name, NOT city — location filter must not suppress based on this."
      }
    },
    {
      "id": "watch-novo",
      "name": "Novo Nordisk Denmark",
      "description": "Scientist/lab tech roles at Novo Nordisk Denmark sites",
      "url": "https://careers.novonordisk.com/search/?q=laboratory+scientist&locationsearch=Denmark",
      "tier": "tier-1",
