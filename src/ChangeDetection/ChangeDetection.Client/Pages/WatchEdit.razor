@page "/watches/new"
@page "/watches/{Id}/edit"
@rendermode InteractiveAuto
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? "Edit Watch" : "Add Watch") - Change Detection</PageTitle>

<div class="watch-edit">
    <header class="edit-header">
        <div class="breadcrumb">
            <a href="/">Dashboard</a>
            <span>/</span>
            @if (IsEditMode)
            {
                <a href="/watches/@Id">Watch Details</a>
                <span>/</span>
                <span>Edit</span>
            }
            else
            {
                <span>Add Watch</span>
            }
        </div>
        <h1>@(IsEditMode ? "Edit Watch" : "Add New Watch")</h1>
    </header>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <EditForm Model="model" OnValidSubmit="HandleSubmit" class="edit-form">
            <DataAnnotationsValidator />

            <section class="form-section">
                <h2>Basic Information</h2>
                
                <div class="form-group">
                    <label for="url">URL *</label>
                    <InputText id="url" @bind-Value="model.Url" class="form-control" placeholder="https://example.com/page" />
                    <ValidationMessage For="@(() => model.Url)" />
                </div>

                <div class="form-group">
                    <label for="title">Title (optional)</label>
                    <InputText id="title" @bind-Value="model.Title" class="form-control" placeholder="My Watch" />
                    <p class="form-hint">A friendly name for this watch. If empty, the domain will be used.</p>
                </div>
            </section>

            <section class="form-section">
                <h2>Organization</h2>
                <p class="section-description">Organize this watch with categories and tags for easier management.</p>

                <div class="form-group">
                    <CategorySelector @bind-SelectedCategoryId="model.CategoryId" Label="Category" />
                </div>

                <div class="form-group">
                    <label>Tags</label>
                    <TagInput @bind-Tags="tagsList" @bind-TagColors="tagColorsDictionary" />
                    <p class="form-hint">Add descriptive tags to help organize and filter your watches.</p>
                </div>
            </section>

            <section class="form-section">
                <h2>Content Selection</h2>
                <p class="section-description">Specify which part of the page to monitor. Leave empty to monitor the entire page.</p>

                <div class="form-group">
                    <label for="cssSelector">CSS Selector</label>
                    <InputText id="cssSelector" @bind-Value="model.CssSelector" class="form-control" placeholder="div.main-content, #article-body" />
                    <p class="form-hint">CSS selector to target specific elements (e.g., <code>.content</code>, <code>#main</code>)</p>
                </div>

                <div class="form-group">
                    <label for="xpathSelector">XPath Selector</label>
                    <InputText id="xpathSelector" @bind-Value="model.XpathSelector" class="form-control" placeholder="//div/span/text()" />
                    <p class="form-hint">XPath expression for more complex selection</p>
                </div>

                <div class="form-group">
                    <label for="ignorePatterns">Ignore Patterns</label>
                    <InputTextArea id="ignorePatterns" @bind-Value="ignorePatternsText" class="form-control" rows="3" 
                                   placeholder="One pattern per line&#10;e.g., timestamp|date|random" />
                    <p class="form-hint">Regex patterns to ignore (one per line). Useful for timestamps, session IDs, etc.</p>
                </div>
            </section>

            <section class="form-section">
                <h2>Check Settings</h2>

                <div class="form-group">
                    <label>Schedule Mode</label>
                    <div class="radio-group">
                        <label class="radio-label">
                            <input type="radio" name="scheduleMode" value="Fixed" @onchange="OnScheduleModeChanged" checked="@(scheduleMode == "Fixed")" />
                            <span>Fixed Interval</span>
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="scheduleMode" value="Adaptive" @onchange="OnScheduleModeChanged" checked="@(scheduleMode == "Adaptive")" />
                            <span>Adaptive (adjusts based on change frequency)</span>
                        </label>
                    </div>
                    <p class="form-hint">
                        @if (scheduleMode == "Fixed")
                        {
                            <span>Check at a fixed interval regardless of how often content changes.</span>
                        }
                        else
                        {
                            <span>Automatically check more frequently for rapidly changing content, less often for stable content.</span>
                        }
                    </p>
                </div>

                @if (scheduleMode == "Fixed")
                {
                    <div class="form-row">
                        <div class="form-group">
                            <label for="checkInterval">Check Interval</label>
                            <div class="input-with-unit">
                                <InputNumber id="checkInterval" @bind-Value="checkIntervalMinutes" class="form-control" min="1" />
                                <select @bind="checkIntervalUnit" class="form-control unit-select">
                                    <option value="minutes">Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <div class="form-group">
                            <label for="baseInterval">Base Interval (starting point)</label>
                            <div class="input-with-unit">
                                <InputNumber id="baseInterval" @bind-Value="baseIntervalValue" class="form-control" min="1" />
                                <select @bind="baseIntervalUnit" class="form-control unit-select">
                                    <option value="minutes">Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                            <p class="form-hint">Initial check interval before adaptive adjustments kick in.</p>
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="minInterval">Minimum Interval</label>
                            <div class="input-with-unit">
                                <InputNumber id="minInterval" @bind-Value="minIntervalValue" class="form-control" min="1" />
                                <select @bind="minIntervalUnit" class="form-control unit-select">
                                    <option value="minutes">Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                            <p class="form-hint">Never check more frequently than this, even for rapidly changing content.</p>
                        </div>
                        <div class="form-group">
                            <label for="maxInterval">Maximum Interval</label>
                            <div class="input-with-unit">
                                <InputNumber id="maxInterval" @bind-Value="maxIntervalValue" class="form-control" min="1" />
                                <select @bind="maxIntervalUnit" class="form-control unit-select">
                                    <option value="minutes">Minutes</option>
                                    <option value="hours">Hours</option>
                                    <option value="days">Days</option>
                                </select>
                            </div>
                            <p class="form-hint">Always check at least this often, even for stable content.</p>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="frequencyMultiplier">Frequency Multiplier</label>
                        <InputNumber id="frequencyMultiplier" @bind-Value="model.ScheduleSettings.FrequencyMultiplier" class="form-control" min="1" max="10" step="0.5" style="max-width: 120px;" />
                        <p class="form-hint">
                            Check @model.ScheduleSettings.FrequencyMultiplier× faster than content typically changes.
                            Higher values catch changes sooner but use more resources.
                        </p>
                    </div>
                }

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="model.IsEnabled" />
                        <span>Enable monitoring</span>
                    </label>
                </div>
            </section>

            <section class="form-section">
                <h2>Fetch Settings</h2>

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="model.FetchSettings.UseJavaScript" />
                        <span>Use JavaScript rendering (Playwright)</span>
                    </label>
                    <p class="form-hint">Enable for pages that load content dynamically with JavaScript</p>
                </div>

                @if (model.FetchSettings.UseJavaScript)
                {
                    <div class="form-group">
                        <label for="waitSelector">Wait for Selector</label>
                        <InputText id="waitSelector" @bind-Value="model.FetchSettings.WaitForSelector" class="form-control" placeholder="#loaded-content" />
                        <p class="form-hint">Wait for this element to appear before capturing content</p>
                    </div>

                    <div class="form-group">
                        <label for="waitTime">Additional Wait Time (ms)</label>
                        <InputNumber id="waitTime" @bind-Value="model.FetchSettings.WaitTimeMs" class="form-control" min="0" max="30000" />
                    </div>

                    <div class="form-group checkbox-group">
                        <label class="checkbox-label">
                            <InputCheckbox @bind-Value="model.FetchSettings.CaptureScreenshot" />
                            <span>Capture screenshot</span>
                        </label>
                    </div>
                }

                <div class="form-group">
                    <label for="timeout">Request Timeout (seconds)</label>
                    <InputNumber id="timeout" @bind-Value="model.FetchSettings.TimeoutSeconds" class="form-control" min="5" max="120" />
                </div>
            </section>

            <section class="form-section">
                <h2>Notifications</h2>

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="model.NotificationSettings.EmailEnabled" />
                        <span>Send email notifications</span>
                    </label>
                </div>

                @if (model.NotificationSettings.EmailEnabled)
                {
                    <div class="form-group">
                        <label for="emails">Email Recipients</label>
                        <InputText id="emails" @bind-Value="emailRecipientsText" class="form-control" placeholder="email@example.com, another@example.com" />
                    </div>
                }

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="model.NotificationSettings.WebhookEnabled" />
                        <span>Send webhook notifications</span>
                    </label>
                </div>

                @if (model.NotificationSettings.WebhookEnabled)
                {
                    <div class="form-group">
                        <label for="webhookUrl">Webhook URL</label>
                        <InputText id="webhookUrl" @bind-Value="model.NotificationSettings.WebhookUrl" class="form-control" placeholder="https://hooks.example.com/notify" />
                    </div>
                }

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <InputCheckbox @bind-Value="model.NotificationSettings.DiscordEnabled" />
                        <span>Send Discord notifications</span>
                    </label>
                </div>

                @if (model.NotificationSettings.DiscordEnabled)
                {
                    <div class="form-group">
                        <label for="discordWebhookUrl">Discord Webhook URL</label>
                        <InputText id="discordWebhookUrl" @bind-Value="model.NotificationSettings.DiscordWebhookUrl" class="form-control" placeholder="https://discord.com/api/webhooks/..." />
                        <small class="form-text">Create a webhook in Discord: Server Settings → Integrations → Webhooks</small>
                    </div>
                }

                <div class="form-group">
                    <label for="minImportance">Minimum Importance to Notify</label>
                    <InputSelect id="minImportance" @bind-Value="model.NotificationSettings.MinimumImportanceToNotify" class="form-control">
                        <option value="Low">Low - All changes</option>
                        <option value="Medium">Medium - Moderate changes only</option>
                        <option value="High">High - Significant changes only</option>
                        <option value="Critical">Critical - Major changes only</option>
                    </InputSelect>
                </div>
            </section>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">
                    @errorMessage
                </div>
            }

            <div class="form-actions">
                <a href="@(IsEditMode ? $"/watches/{Id}" : "/")" class="btn btn-outline">Cancel</a>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-small"></span>
                    }
                    @(IsEditMode ? "Save Changes" : "Create Watch")
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private bool IsEditMode => !string.IsNullOrEmpty(Id);

    private WatchCreateDto model = new()
    {
        Url = "",
        CheckInterval = TimeSpan.FromHours(1),
        IsEnabled = true,
        FetchSettings = new FetchSettingsDto
        {
            TimeoutSeconds = 30
        },
        NotificationSettings = new NotificationSettingsDto
        {
            MinimumImportanceToNotify = "Medium"
        },
        ScheduleSettings = new CheckScheduleSettingsDto
        {
            Mode = "Fixed",
            BaseInterval = TimeSpan.FromHours(1),
            MinInterval = TimeSpan.FromHours(1),
            MaxInterval = TimeSpan.FromDays(7),
            FrequencyMultiplier = 3.0
        }
    };

    // Fixed interval fields
    private int checkIntervalMinutes = 60;
    private string checkIntervalUnit = "minutes";
    
    // Adaptive interval fields
    private string scheduleMode = "Fixed";
    private int baseIntervalValue = 1;
    private string baseIntervalUnit = "hours";
    private int minIntervalValue = 1;
    private string minIntervalUnit = "hours";
    private int maxIntervalValue = 7;
    private string maxIntervalUnit = "days";
    
    private string ignorePatternsText = "";
    private string emailRecipientsText = "";
    private List<TagDto> tagsList = [];
    private Dictionary<string, string> tagColorsDictionary = [];
    private bool isLoading = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    
    private void OnScheduleModeChanged(ChangeEventArgs e)
    {
        scheduleMode = e.Value?.ToString() ?? "Fixed";
        model.ScheduleSettings.Mode = scheduleMode;
    }

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            await LoadWatch();
        }
    }

    private async Task LoadWatch()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetAsync($"/api/watches/{Id}");
            if (response.IsSuccessStatusCode)
            {
                var watch = await response.Content.ReadFromJsonAsync<WatchDetailDto>();
                if (watch != null)
                {
                    model = new WatchCreateDto
                    {
                        Url = watch.Url,
                        Title = watch.Title,
                        CssSelector = watch.CssSelector,
                        XpathSelector = watch.XpathSelector,
                        IgnorePatterns = watch.IgnorePatterns,
                        CheckInterval = watch.CheckInterval,
                        IsEnabled = watch.IsEnabled,
                        FetchSettings = new FetchSettingsDto
                        {
                            UseJavaScript = watch.FetchSettings?.UseJavaScript ?? false,
                            WaitForSelector = watch.FetchSettings?.WaitForSelector,
                            WaitTimeMs = watch.FetchSettings?.WaitTimeMs ?? 0,
                            CaptureScreenshot = watch.FetchSettings?.CaptureScreenshot ?? false,
                            TimeoutSeconds = watch.FetchSettings?.TimeoutSeconds ?? 30
                        },
                        NotificationSettings = new NotificationSettingsDto
                        {
                            EmailEnabled = watch.NotificationSettings?.EmailEnabled ?? false,
                            EmailRecipients = watch.NotificationSettings?.EmailRecipients ?? new(),
                            WebhookEnabled = watch.NotificationSettings?.WebhookEnabled ?? false,
                            WebhookUrl = watch.NotificationSettings?.WebhookUrl,
                            DiscordEnabled = watch.NotificationSettings?.DiscordEnabled ?? false,
                            DiscordWebhookUrl = watch.NotificationSettings?.DiscordWebhookUrl,
                            MinimumImportanceToNotify = watch.NotificationSettings?.MinimumImportanceToNotify ?? "Medium"
                        },
                        ScheduleSettings = watch.ScheduleSettings ?? new CheckScheduleSettingsDto()
                    };

                    // Set schedule mode and interval values
                    scheduleMode = watch.ScheduleSettings?.Mode ?? "Fixed";
                    
                    // Set fixed interval values
                    var interval = watch.CheckInterval;
                    if (interval.TotalDays >= 1)
                    {
                        checkIntervalMinutes = (int)interval.TotalDays;
                        checkIntervalUnit = "days";
                    }
                    else if (interval.TotalHours >= 1)
                    {
                        checkIntervalMinutes = (int)interval.TotalHours;
                        checkIntervalUnit = "hours";
                    }
                    else
                    {
                        checkIntervalMinutes = Math.Max(1, (int)interval.TotalMinutes);
                        checkIntervalUnit = "minutes";
                    }
                    
                    // Set adaptive interval values
                    var baseInterval = watch.ScheduleSettings?.BaseInterval ?? TimeSpan.FromHours(1);
                    SetIntervalFields(baseInterval, out baseIntervalValue, out baseIntervalUnit);
                    
                    var minInterval = watch.ScheduleSettings?.MinInterval ?? TimeSpan.FromHours(1);
                    SetIntervalFields(minInterval, out minIntervalValue, out minIntervalUnit);
                    
                    var maxInterval = watch.ScheduleSettings?.MaxInterval ?? TimeSpan.FromDays(7);
                    SetIntervalFields(maxInterval, out maxIntervalValue, out maxIntervalUnit);

                    ignorePatternsText = string.Join("\n", watch.IgnorePatterns ?? new());
                    emailRecipientsText = string.Join(", ", watch.NotificationSettings?.EmailRecipients ?? new());
                    
                    // Set tags and category
                    tagsList = watch.Tags?.ToList() ?? [];
                    model.CategoryId = watch.CategoryId;

                    // Build tag colors dictionary from tags that have overrides
                    tagColorsDictionary = tagsList
                        .Where(t => t.IsColorOverridden && !string.IsNullOrEmpty(t.Color))
                        .ToDictionary(t => t.Name, t => t.Color);
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Parse interval for fixed mode
            model.CheckInterval = checkIntervalUnit switch
            {
                "hours" => TimeSpan.FromHours(checkIntervalMinutes),
                "days" => TimeSpan.FromDays(checkIntervalMinutes),
                _ => TimeSpan.FromMinutes(checkIntervalMinutes)
            };
            
            // Set schedule settings
            model.ScheduleSettings.Mode = scheduleMode;
            
            if (scheduleMode == "Adaptive")
            {
                model.ScheduleSettings.BaseInterval = GetIntervalFromFields(baseIntervalValue, baseIntervalUnit);
                model.ScheduleSettings.MinInterval = GetIntervalFromFields(minIntervalValue, minIntervalUnit);
                model.ScheduleSettings.MaxInterval = GetIntervalFromFields(maxIntervalValue, maxIntervalUnit);
                // For adaptive mode, also set check interval to base interval initially
                model.CheckInterval = model.ScheduleSettings.BaseInterval;
            }
            else
            {
                // For fixed mode, sync base interval with check interval
                model.ScheduleSettings.BaseInterval = model.CheckInterval;
            }

            // Parse ignore patterns
            model.IgnorePatterns = ignorePatternsText
                .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                .Select(p => p.Trim())
                .Where(p => !string.IsNullOrEmpty(p))
                .ToList();

            // Parse email recipients
            model.NotificationSettings.EmailRecipients = emailRecipientsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(e => e.Trim())
                .Where(e => !string.IsNullOrEmpty(e))
                .ToList();

            // Set tags and tag colors
            model.Tags = tagsList.Select(t => t.Name).ToList();
            model.TagColors = tagColorsDictionary;

            HttpResponseMessage response;
            if (IsEditMode)
            {
                response = await Http.PutAsJsonAsync($"/api/watches/{Id}", model);
            }
            else
            {
                response = await Http.PostAsJsonAsync("/api/watches", model);
            }

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<WatchDetailDto>();
                Navigation.NavigateTo($"/watches/{result?.Id ?? Id}");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to save: {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
    
    private static void SetIntervalFields(TimeSpan interval, out int value, out string unit)
    {
        if (interval.TotalDays >= 1)
        {
            value = (int)interval.TotalDays;
            unit = "days";
        }
        else if (interval.TotalHours >= 1)
        {
            value = (int)interval.TotalHours;
            unit = "hours";
        }
        else
        {
            value = Math.Max(1, (int)interval.TotalMinutes);
            unit = "minutes";
        }
    }
    
    private static TimeSpan GetIntervalFromFields(int value, string unit)
    {
        return unit switch
        {
            "hours" => TimeSpan.FromHours(value),
            "days" => TimeSpan.FromDays(value),
            _ => TimeSpan.FromMinutes(value)
        };
    }
}
