@page "/"
@page "/{ViewId?}"
@rendermode InteractiveAuto
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.SignalR.Client
@using ChangeDetection.Shared.Dtos
@using ChangeDetection.Client.Components
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject LocalStorageService LocalStorage
@inject KeyboardShortcutService ShortcutService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Command Center - Change Detection</PageTitle>

<div class="command-center">
    <!-- Hero Add Watch Section -->
    <section class="add-watch-hero">
        <div class="hero-content">
            <h1 class="hero-title">Add a new web page change detection watch</h1>
            
            <div class="add-watch-form">
                <SmartInput Placeholder="https://... or describe what you want to watch" />

                @if (creationMessage is not null)
                {
                    <div class="alert @(creationIsError ? "alert-error" : "alert-success")">
                        @creationMessage
                        <button class="alert-dismiss" @onclick="ClearCreationMessage">✕</button>
                    </div>
                }
            </div>

            <p class="hero-hint">💡 Paste a URL or describe what you want to monitor in plain English</p>
        </div>
    </section>

    <!-- Health Status Grid -->
    <section class="health-grid-section">
        <div class="health-grid">
            <button class="health-card health-card-total @(IsHealthFilterActive(null) ? "active" : "")" @onclick="() => SetHealthFilter(null)">
                <div class="health-card-icon">📊</div>
                <div class="health-card-count">@watches.Count</div>
                <div class="health-card-label">Total Watches</div>
            </button>
            <button class="health-card health-card-healthy @(IsHealthFilterActive("Active") ? "active" : "")" @onclick='() => SetHealthFilter("Active")'>
                <div class="health-card-icon">✓</div>
                <div class="health-card-count">@GetHealthyCount()</div>
                <div class="health-card-label">Active / Healthy</div>
            </button>
            <button class="health-card health-card-checking @(IsHealthFilterActive("Checking") ? "active" : "")" @onclick='() => SetHealthFilter("Checking")'>
                <div class="health-card-icon">⏳</div>
                <div class="health-card-count">@GetCheckingCount()</div>
                <div class="health-card-label">Checking</div>
            </button>
            <button class="health-card health-card-error @(IsHealthFilterActive("Error") ? "active" : "")" @onclick='() => SetHealthFilter("Error")'>
                <div class="health-card-icon">⚠</div>
                <div class="health-card-count">@GetErrorCount()</div>
                <div class="health-card-label">Errors</div>
            </button>
            <button class="health-card health-card-paused @(IsHealthFilterActive("Paused") ? "active" : "")" @onclick='() => SetHealthFilter("Paused")'>
                <div class="health-card-icon">⏸</div>
                <div class="health-card-count">@GetPausedCount()</div>
                <div class="health-card-label">Paused</div>
            </button>
        </div>
    </section>

    <!-- Top Bar -->
    <header class="cmd-bar">
        <div class="cmd-search">
            <span class="search-icon">🔍</span>
            <input type="text" id="home-search-input" placeholder="Filter watches..." @bind="searchText" @bind:event="oninput" @onblur="HandleSearchBlur" />
        </div>

        <div class="cmd-actions">
            <button class="btn-cmd @(isBulkMode ? "active" : "")" @onclick="ToggleBulkMode" title="@(isBulkMode ? "Exit bulk edit mode" : "Enter bulk edit mode")">
                <span class="icon">☑️</span> @(isBulkMode ? "Done" : "Select")
            </button>
            <button class="btn-cmd" @onclick="RunAllChecks" disabled="@isCheckingAll">
                <span class="icon">@(isCheckingAll ? "⏳" : "▶")</span> Run All
            </button>
            <button class="btn-cmd" @onclick="GoToSettings">
                <span class="icon">⚙️</span>
            </button>
        </div>
    </header>

    <!-- Bulk Actions Bar (shown when in bulk mode with selections) -->
    @if (isBulkMode)
    {
        <div class="bulk-actions-bar">
            <div class="bulk-selection-info">
                <input type="checkbox" 
                       checked="@IsAllSelected" 
                       @onchange="ToggleSelectAll" 
                       title="Select all" />
                <span>@selectedWatchIds.Count selected</span>
            </div>
            <div class="bulk-actions">
                <button class="btn-bulk" @onclick="BulkEnable" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Enable selected watches" aria-label="Enable selected watches">
                    <span class="icon">✓</span> Enable
                </button>
                <button class="btn-bulk" @onclick="BulkDisable" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Disable selected watches" aria-label="Disable selected watches">
                    <span class="icon">⏸</span> Disable
                </button>
                <button class="btn-bulk" @onclick="BulkCheck" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Check selected watches now" aria-label="Check selected watches now">
                    <span class="icon">▶</span> Check Now
                </button>
                <button class="btn-bulk btn-bulk-edit" @onclick="OpenBulkEditDialog" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Edit selected watches" aria-label="Edit selected watches">
                    <span class="icon">✎</span> Edit
                </button>
                <button class="btn-bulk btn-bulk-danger" @onclick="BulkDelete" disabled="@(selectedWatchIds.Count == 0 || isBulkOperating)" title="Delete selected watches" aria-label="Delete selected watches">
                    <span class="icon">🗑</span> Delete
                </button>
            </div>
            @if (bulkOperationMessage is not null)
            {
                <div class="bulk-message @(bulkOperationIsError ? "error" : "success")">
                    @bulkOperationMessage
                    <button class="dismiss-btn" @onclick="ClearBulkMessage">✕</button>
                </div>
            }
        </div>
    }

    <!-- Main Content Area -->
    <div class="cmd-main">
        <!-- Watch Groups Section -->
        @if (watchGroups.Any())
        {
            <div class="groups-section">
                <div class="panel-toolbar">
                    <h3 class="section-title">📊 Watch Groups</h3>
                </div>
                @foreach (var group in watchGroups)
                {
                    <WatchGroupCard Group="group"
                                    Detail="@expandedGroupDetails.GetValueOrDefault(group.Id)"
                                    Health="@expandedGroupHealth.GetValueOrDefault(group.Id)"
                                    OnExpandToggled="OnGroupExpanded" />
                }
            </div>
        }

        <!-- Watch List Panel -->
        <div class="watch-panel">
            <div class="panel-toolbar">
                <div class="filter-group">
                    <button class="filter-chip @(activeStatusFilter == null && !changedRecentlyFilter ? "active" : "")" @onclick="() => SetFilter(null)">All</button>
                    <button class="filter-chip @(activeStatusFilter == "Active" ? "active" : "")" @onclick='() => SetFilter("Active")'>Active</button>
                    <button class="filter-chip @(activeStatusFilter == "Checking" ? "active" : "")" @onclick='() => SetFilter("Checking")'>Checking</button>
                    <button class="filter-chip @(activeStatusFilter == "Error" ? "active" : "")" @onclick='() => SetFilter("Error")'>Errors</button>
                    <button class="filter-chip @(changedRecentlyFilter ? "active" : "")" @onclick="ToggleChangedFilter">Changed Recently</button>
                </div>
                <div class="stats-summary">
                    <span>@watches.Count Total</span>
                    @if (pendingSetups.Any())
                    {
                        <span class="separator">|</span>
                        <span class="text-warning">@pendingSetups.Count Setting up</span>
                    }
                    @{
                        var checkingCount = watches.Count(w => w.Status == "Checking");
                    }
                    @if (checkingCount > 0)
                    {
                        <span class="separator">|</span>
                        <span class="text-info">@checkingCount Checking</span>
                    }
                    <span class="separator">|</span>
                    <span class="text-success">@watches.Count(w => w.Status == "Active") Active</span>
                    <span class="separator">|</span>
                    <span class="text-danger">@watches.Count(w => w.Status == "Error") Errors</span>
                </div>
            </div>

            <div class="data-grid-container">
                @if (isLoading)
                {
                    <div class="loading-state">Loading watches...</div>
                }
                else if (FilteredWatches.Any() || pendingSetups.Any())
                {
                    <table class="data-grid">
                        <thead>
                            <tr>
                                @if (isBulkMode)
                                {
                                    <th scope="col" width="40" class="checkbox-cell">
                                        <input type="checkbox" 
                                               checked="@IsAllSelected" 
                                               @onchange="ToggleSelectAll" 
                                               title="Select all" 
                                               aria-label="Select all watches" />
                                    </th>
                                }
                                <th scope="col" width="40">St</th>
                                <th scope="col">Name / URL</th>
                                <th scope="col" width="120">Last Check</th>
                                <th scope="col" width="120">Last Change</th>
                                <th scope="col">Tags</th>
                                <th scope="col" width="120" class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Pending setup sessions appear first *@
                            @foreach (var setup in pendingSetups)
                            {
                                <tr class="grid-row pending-setup-row" @onclick="() => ResumeSetup(setup.SessionId)">
                                    @if (isBulkMode)
                                    {
                                        <td class="checkbox-cell" @onclick:stopPropagation>
                                            <!-- Pending setups are not selectable -->
                                        </td>
                                    }
                                    <td class="status-cell">
                                        <div class="status-indicator @(setup.IsProcessing ? "checking" : "pending")" title="@GetSetupStatusTitle(setup)">
                                            @if (!setup.IsProcessing && !string.IsNullOrEmpty(setup.CurrentPrompt))
                                            {
                                                <span class="needs-input-badge">!</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="name-cell">
                                        <div class="watch-title pending-title">
                                            <span class="pending-icon">@(setup.IsProcessing ? "⚙️" : "⏳")</span>
                                            @(setup.DisplayName ?? "New Watch")
                                            @if (!setup.IsProcessing && !string.IsNullOrEmpty(setup.CurrentPrompt))
                                            {
                                                <span class="needs-input-label">Needs input</span>
                                            }
                                            else if (setup.IsProcessing)
                                            {
                                                <span class="processing-label">Processing...</span>
                                            }
                                        </div>
                                        <div class="watch-url pending-prompt">@GetSetupStatusText(setup)</div>
                                    </td>
                                    <td class="meta-cell">
                                        <span class="text-muted">-</span>
                                    </td>
                                    <td class="meta-cell">
                                        <span class="text-muted">-</span>
                                    </td>
                                    <td class="tags-cell">
                                        <span class="tag-badge @GetSetupTagClass(setup)">@GetSetupTagText(setup)</span>
                                    </td>
                                    <td class="actions-cell" @onclick:stopPropagation>
                                        <button class="btn-icon btn-resume" title="@(setup.IsProcessing ? "View Progress" : "Resume Setup")" aria-label="@(setup.IsProcessing ? "View Progress" : "Resume Setup")" @onclick="() => ResumeSetup(setup.SessionId)">→</button>
                                        <button class="btn-icon btn-cancel" title="Cancel Setup" aria-label="Cancel Setup" @onclick="() => CancelSetup(setup.SessionId)">✕</button>
                                    </td>
                                </tr>
                            }
                            @* Regular watches *@
                            @foreach (var watch in FilteredWatches)
                            {
                                <tr class="grid-row @(watch.HasRecentChanges ? "highlight-change" : "") @(selectedWatchIds.Contains(watch.Id) ? "selected" : "")" @onclick="() => OnRowClick(watch.Id)">
                                    @if (isBulkMode)
                                    {
                                        <td class="checkbox-cell" @onclick:stopPropagation>
                                            <input type="checkbox" 
                                                   checked="@selectedWatchIds.Contains(watch.Id)" 
                                                   @onchange="() => ToggleWatchSelection(watch.Id)" />
                                        </td>
                                    }
                                    <td class="status-cell">
                                        <div class="status-indicator @watch.Status.ToLower()" title="@watch.Status"></div>
                                    </td>
                                    <td class="name-cell">
                                        <div class="watch-title">@GetDisplayTitle(watch)</div>
                                        <div class="watch-url">@TruncateUrl(watch.Url)</div>
                                    </td>
                                    <td class="meta-cell">
                                        @if (watch.LastCheck.HasValue)
                                        {
                                            <span title="@watch.LastCheck">@FormatTimeAgo(watch.LastCheck.Value)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="meta-cell">
                                        @if (watch.LatestChangeAt.HasValue)
                                        {
                                            <span class="change-time" title="@watch.LatestChangeAt">@FormatTimeAgo(watch.LatestChangeAt.Value)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="tags-cell">
                                        @foreach (var tag in watch.Tags.Take(3))
                                        {
                                            <span class="tag-badge" style="background-color: @tag.Color">@tag.Name</span>
                                        }
                                        @if (watch.Tags.Count > 3)
                                        {
                                            <span class="tag-more">+@(watch.Tags.Count - 3)</span>
                                        }
                                    </td>
                                    <td class="actions-cell" @onclick:stopPropagation>
                                        <button class="btn-icon" title="Check Now" aria-label="Check Now" @onclick="() => TriggerCheck(watch.Id)">▶</button>
                                        <button class="btn-icon" title="Edit" aria-label="Edit" @onclick="() => NavigateToEdit(watch.Id)">✎</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <span>No watches found.</span>
                        <span class="empty-hint">Use the form above to add your first watch.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar: Recent Activity -->
        <div class="sidebar-panel">
            <div class="panel-header">
                <h3>Recent Activity</h3>
            </div>
            <div class="activity-feed">
                @* Show watches currently being checked (from DB or SignalR) *@
                @foreach (var checking in GetCheckingWatches())
                {
                    <div class="feed-item processing" @onclick="() => NavigateToWatch(checking.Id)">
                        <div class="feed-icon processing-icon">⏳</div>
                        <div class="feed-content">
                            <div class="feed-title">@checking.Name</div>
                            <div class="feed-summary">Checking for changes...</div>
                            <div class="feed-time">@(checking.StartedAt.HasValue ? FormatTimeAgo(checking.StartedAt.Value) : "now")</div>
                        </div>
                    </div>
                }
                @* Then show grouped recent changes by time bucket *@
                @if (recentChanges.Any())
                {
                    @foreach (var bucket in GetTimeBuckets())
                    {
                        var bucketGroups = GetGroupedChangesForBucket(bucket);
                        @if (bucketGroups.Any())
                        {
                            <div class="time-bucket-header">@bucket</div>
                            @foreach (var group in bucketGroups)
                            {
                                @if (group.Changes.Count == 1)
                                {
                                    var change = group.Changes[0];
                                    <div class="feed-item @GetImportanceClass(change.Importance) @(change.IsViewed ? "" : "unread")" @onclick="() => NavigateToChange(change.Id)">
                                        <div class="feed-icon-wrapper">
                                            @if (change.Importance == "High")
                                            {
                                                <span class="feed-icon importance-high">🔴</span>
                                            }
                                            else if (change.Importance == "Medium")
                                            {
                                                <span class="feed-icon importance-medium">🟡</span>
                                            }
                                            else
                                            {
                                                <span class="feed-icon">🟢</span>
                                            }
                                        </div>
                                        <div class="feed-content">
                                            <div class="feed-title-row">
                                                <span class="feed-title">@change.WatchTitle</span>
                                                @if (change.Importance != "Low")
                                                {
                                                    <span class="importance-badge @change.Importance.ToLower()">@change.Importance</span>
                                                }
                                            </div>
                                            <div class="feed-summary">@TruncateSummary(change.Summary, 60)</div>
                                            <div class="feed-time">@FormatTimeAgo(change.DetectedAt)</div>
                                        </div>
                                        <div class="feed-actions">
                                            <button class="feed-action-btn" title="View change" @onclick="() => NavigateToChange(change.Id)" @onclick:stopPropagation>👁</button>
                                            <button class="feed-action-btn" title="Mark as read" @onclick="() => MarkAsRead(change.Id)" @onclick:stopPropagation>✓</button>
                                            <div class="snooze-dropdown" @onclick:stopPropagation>
                                                <button class="feed-action-btn" title="Snooze" aria-label="Snooze notifications">💤</button>
                                                <div class="snooze-menu">
                                                    <button @onclick="() => SnoozeWatch(change.WatchId, 1)">1 hour</button>
                                                    <button @onclick="() => SnoozeWatch(change.WatchId, 4)">4 hours</button>
                                                    <button @onclick="() => SnoozeWatch(change.WatchId, 24)">24 hours</button>
                                                    <button @onclick="() => SnoozeWatch(change.WatchId, 168)">1 week</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    var isExpanded = expandedGroups.Contains(group.WatchId);
                                    var highestImportance = group.Changes.OrderByDescending(c => GetImportanceOrder(c.Importance)).First().Importance;
                                    var hasUnread = group.Changes.Any(c => !c.IsViewed);
                                    <div class="feed-group @GetImportanceClass(highestImportance) @(hasUnread ? "unread" : "")">
                                        <div class="feed-group-header" @onclick="() => ToggleGroupExpand(group.WatchId)">
                                            <div class="feed-icon-wrapper">
                                                @if (highestImportance == "High")
                                                {
                                                    <span class="feed-icon importance-high">🔴</span>
                                                }
                                                else if (highestImportance == "Medium")
                                                {
                                                    <span class="feed-icon importance-medium">🟡</span>
                                                }
                                                else
                                                {
                                                    <span class="feed-icon">🟢</span>
                                                }
                                            </div>
                                            <div class="feed-content">
                                                <div class="feed-title-row">
                                                    <span class="feed-title">@group.WatchTitle</span>
                                                    <span class="group-count">@group.Changes.Count changes</span>
                                                </div>
                                                <div class="feed-summary">@group.Changes.Count changes in the last @GetBucketDuration(bucket)</div>
                                                <div class="feed-time">Latest: @FormatTimeAgo(group.Changes.Max(c => c.DetectedAt))</div>
                                            </div>
                                            <span class="expand-icon">@(isExpanded ? "▼" : "▶")</span>
                                        </div>
                                        @if (isExpanded)
                                        {
                                            <div class="feed-group-items">
                                                @foreach (var change in group.Changes.OrderByDescending(c => c.DetectedAt))
                                                {
                                                    <div class="feed-item nested @GetImportanceClass(change.Importance) @(change.IsViewed ? "" : "unread")" @onclick="() => NavigateToChange(change.Id)">
                                                        <div class="feed-icon-wrapper">
                                                            @if (change.Importance == "High")
                                                            {
                                                                <span class="feed-icon importance-high">🔴</span>
                                                            }
                                                            else if (change.Importance == "Medium")
                                                            {
                                                                <span class="feed-icon importance-medium">🟡</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="feed-icon">🟢</span>
                                                            }
                                                        </div>
                                                        <div class="feed-content">
                                                            <div class="feed-title-row">
                                                                <span class="feed-summary">@TruncateSummary(change.Summary, 50)</span>
                                                                @if (change.Importance != "Low")
                                                                {
                                                                    <span class="importance-badge @change.Importance.ToLower()">@change.Importance</span>
                                                                }
                                                            </div>
                                                            <div class="feed-time">@FormatTimeAgo(change.DetectedAt)</div>
                                                        </div>
                                                        <div class="feed-actions">
                                                            <button class="feed-action-btn" title="View change" @onclick="() => NavigateToChange(change.Id)" @onclick:stopPropagation>👁</button>
                                                            <button class="feed-action-btn" title="Mark as read" @onclick="() => MarkAsRead(change.Id)" @onclick:stopPropagation>✓</button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="feed-group-actions">
                                            <button class="feed-action-btn-text" @onclick="() => MarkGroupAsRead(group.WatchId)" @onclick:stopPropagation>Mark all read</button>
                                            <div class="snooze-dropdown" @onclick:stopPropagation>
                                                <button class="feed-action-btn-text" aria-label="Snooze notifications">Snooze ▾</button>
                                                <div class="snooze-menu">
                                                    <button @onclick="() => SnoozeWatch(group.WatchId, 1)">1 hour</button>
                                                    <button @onclick="() => SnoozeWatch(group.WatchId, 4)">4 hours</button>
                                                    <button @onclick="() => SnoozeWatch(group.WatchId, 24)">24 hours</button>
                                                    <button @onclick="() => SnoozeWatch(group.WatchId, 168)">1 week</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        }
                    }
                }
                else if (!GetCheckingWatches().Any())
                {
                    <div class="empty-feed">
                        <div class="empty-feed-icon">📭</div>
                        <div class="empty-feed-title">No recent activity</div>
                        <div class="empty-feed-hint">Changes will appear here when detected</div>
                    </div>
                }
            </div>
            
            @* Snoozed Watches Section *@
            @if (snoozedWatchIds.Any())
            {
                <div class="snoozed-section">
                    <div class="snoozed-header">Snoozed (@snoozedWatchIds.Count)</div>
                    @foreach (var watchId in snoozedWatchIds.ToList())
                    {
                        var watch = watches.FirstOrDefault(w => w.Id == watchId);
                        if (watch != null && IsWatchSnoozed(watchId))
                        {
                            <div class="snoozed-item">
                                <span class="snoozed-item-title">@(watch.Title ?? watch.Url)</span>
                                <span class="snoozed-item-time">until @FormatSnoozeExpiration(watchId)</span>
                                <button class="snoozed-item-unsnooze" @onclick="() => UnsnoozeWatch(watchId)" aria-label="Un-snooze">🔔</button>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>

</div>

@* Bulk Edit Dialog *@
@if (showBulkEditDialog)
{
    <div class="modal-overlay" @onclick="CloseBulkEditDialog">
        <div class="bulk-edit-dialog" @onclick:stopPropagation>
            <div class="dialog-header">
                <h2>Edit @selectedWatchIds.Count Watches</h2>
                <button class="dialog-close" @onclick="CloseBulkEditDialog">✕</button>
            </div>
            <div class="dialog-content">
                <div class="form-group">
                    <label>Add Tags</label>
                    <input type="text" 
                           class="form-control" 
                           placeholder="tag1, tag2, tag3" 
                           @bind="bulkEditModel.AddTags" />
                    <small class="form-hint">Comma-separated tags to add to all selected watches</small>
                </div>

                <div class="form-group">
                    <label>Remove Tags</label>
                    <input type="text" 
                           class="form-control" 
                           placeholder="tag1, tag2" 
                           @bind="bulkEditModel.RemoveTags" />
                    <small class="form-hint">Comma-separated tags to remove from all selected watches</small>
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeCheckInterval" />
                        <span>Change check interval</span>
                    </label>
                    @if (bulkEditModel.ChangeCheckInterval)
                    {
                        <div class="interval-input">
                            <input type="number" 
                                   class="form-control" 
                                   min="1" 
                                   @bind="checkIntervalMinutes" />
                            <span>minutes</span>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeUseJavaScript" />
                        <span>Change JavaScript rendering</span>
                    </label>
                    @if (bulkEditModel.ChangeUseJavaScript)
                    {
                        <label class="checkbox-label sub-option">
                            <input type="checkbox" @bind="bulkEditModel.UseJavaScript" />
                            <span>Enable JavaScript rendering</span>
                        </label>
                    }
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="bulkEditModel.ChangeNotifications" />
                        <span>Change notifications</span>
                    </label>
                    @if (bulkEditModel.ChangeNotifications)
                    {
                        <label class="checkbox-label sub-option">
                            <input type="checkbox" @bind="bulkEditModel.NotificationsEnabled" />
                            <span>Enable notifications</span>
                        </label>
                    }
                </div>
            </div>
            <div class="dialog-footer">
                <button class="btn-secondary" @onclick="CloseBulkEditDialog">Cancel</button>
                <button class="btn-primary" @onclick="ApplyBulkEdit" disabled="@isBulkOperating">
                    @if (isBulkOperating)
                    {
                        <span>Applying...</span>
                    }
                    else
                    {
                        <span>Apply Changes</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

