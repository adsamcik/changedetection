@inject NavigationManager Navigation
@inject HttpClient Http

<div class="smart-input-container">
    <div class="input-wrapper">
        <textarea @ref="_inputElement"
                  @bind="InputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="@Placeholder"
                  class="smart-input"
                  rows="2" />
    </div>

    @if (_isSubmitting)
    {
        <div class="mode-indicator submitting">
            <span>⏳ Starting setup...</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mode-indicator error">
            <span>⚠️ @_errorMessage</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(InputText))
    {
        <div class="mode-indicator">
            <span>✨ Press Enter to start setup</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Placeholder { get; set; } = "Paste a URL or describe what you want to watch...";

    private ElementReference _inputElement;
    private string _inputText = "";
    private bool _isSubmitting;
    private string? _errorMessage;

    private string InputText
    {
        get => _inputText;
        set => _inputText = value;
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            return ProcessInput();
        }
        else if (e.Key == "Escape")
        {
            _inputText = "";
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task ProcessInput()
    {
        if (string.IsNullOrWhiteSpace(_inputText))
            return;

        var trimmedInput = _inputText.Trim();
        _isSubmitting = true;
        StateHasChanged();
        
        try
        {
            // Start the setup session on the server - this begins processing immediately
            var response = await Http.PostAsJsonAsync("/api/llm/start-setup", new { Input = trimmedInput });
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<StartSetupResponse>();
                if (result != null)
                {
                    // Navigate to setup page - no query params needed, session already has the input
                    Navigation.NavigateTo($"/setup/{result.SessionId}");
                    return;
                }
            }
            
            // Fallback: show error
            _errorMessage = "Failed to start setup. Please try again.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private record StartSetupResponse(Guid SessionId, DateTimeOffset CreatedAt);
}
