@inject NavigationManager Navigation

<div class="smart-input-container">
    <label for="smart-input" class="visually-hidden">Describe what you want to watch or paste a URL</label>
    <div class="input-wrapper">
        <textarea id="smart-input"
                  @ref="_inputElement"
                  @bind="InputText"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="@Placeholder"
                  class="smart-input"
                  aria-label="Describe what you want to watch or paste a URL"
                  rows="2" />
        <button class="smart-input-submit"
                @onclick="ProcessInput"
                disabled="@string.IsNullOrWhiteSpace(InputText)"
                aria-label="Start monitoring"
                title="Start monitoring (Enter)">
            →
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mode-indicator error" role="alert">
            <span>⚠️ @_errorMessage</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(InputText))
    {
        <div class="mode-indicator" aria-live="polite">
            <span>💡 Paste a URL or describe what you want to monitor in plain English</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Placeholder { get; set; } = "Paste a URL or describe what you want to watch...";

    private ElementReference _inputElement;
    private string _inputText = "";
    private string? _errorMessage;

    private string InputText
    {
        get => _inputText;
        set => _inputText = value;
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            return ProcessInput();
        }
        else if (e.Key == "Escape")
        {
            _inputText = "";
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task ProcessInput()
    {
        if (string.IsNullOrWhiteSpace(_inputText))
            return Task.CompletedTask;

        var trimmedInput = _inputText.Trim();

        // Route directly based on input type — no wasted hub connections
        if (LooksLikeUrl(trimmedInput))
            Navigation.NavigateTo($"/setup?input={Uri.EscapeDataString(trimmedInput)}");
        else
            Navigation.NavigateTo($"/groupwatch/setup?input={Uri.EscapeDataString(trimmedInput)}");

        return Task.CompletedTask;
    }

    private static bool LooksLikeUrl(string input)
    {
        if (input.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            input.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Uri.TryCreate($"https://{input}", UriKind.Absolute, out var uri) &&
            (uri.Host.Contains('.') || uri.Host == "localhost" || System.Net.IPAddress.TryParse(uri.Host, out _)) &&
            !input.Contains(' '))
            return true;

        return false;
    }
}
